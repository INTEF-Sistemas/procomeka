# Base de datos (vacío = PGlite local para desarrollo, sin instalar PostgreSQL)
# DATABASE_URL=postgres://user:pass@localhost:5432/procomeka

# URL pública — todo se expone por el puerto del frontend
# El proxy de Astro reenvía /api/* al backend internamente
BETTER_AUTH_URL=http://localhost:4321
FRONTEND_URL=http://localhost:4321

# OpenID Connect (SSO) — Duende demo server
# Usuario de prueba: bob / bob (o alice / alice)
OIDC_ENABLED=true
OIDC_ISSUER=https://demo.duendesoftware.com
OIDC_CLIENT_ID=interactive.confidential
OIDC_CLIENT_SECRET=secret
OIDC_SCOPE=openid email profile
