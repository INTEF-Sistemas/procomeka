# Base de datos (vacío = PGlite local para desarrollo, sin instalar PostgreSQL)
# DATABASE_URL=postgres://user:pass@localhost:5432/procomeka

# URL pública de la aplicación en desarrollo local.
# El navegador entra por el frontend (4321) y Astro hace proxy de /api/* al backend (3000).
# BETTER_AUTH_URL debe apuntar a esta URL pública, no al puerto interno de la API.
BETTER_AUTH_URL=http://localhost:4321
FRONTEND_URL=http://localhost:4321

# OpenID Connect (SSO) opcional — Duende demo server
# Si OIDC_ENABLED no está en true, el login institucional no se activa.
# Usuario de prueba: bob / bob (o alice / alice)
OIDC_ENABLED=true
OIDC_ISSUER=https://demo.duendesoftware.com
OIDC_CLIENT_ID=interactive.confidential
OIDC_CLIENT_SECRET=secret
OIDC_SCOPE=openid email profile

# Uploads resumables
UPLOAD_STORAGE_DIR=./local-data/uploads
UPLOAD_MAX_FILE_SIZE_BYTES=10737418240
UPLOAD_MAX_FILES_PER_BATCH=20
UPLOAD_MAX_CONCURRENT_PER_USER=3
UPLOAD_CHUNK_SIZE_BYTES=5242880
UPLOAD_SESSION_TTL_MS=86400000
# Valores CSV. Ajusta a tu operación real.
UPLOAD_ALLOWED_EXTENSIONS=.pdf,.doc,.docx,.ppt,.pptx,.zip,.scorm,.mp4,.mp3,.wav,.png,.jpg,.jpeg,.gif,.webp,.csv,.json
UPLOAD_ALLOWED_MIME_TYPES=application/pdf,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document,application/vnd.ms-powerpoint,application/vnd.openxmlformats-officedocument.presentationml.presentation,application/zip,application/x-zip-compressed,application/json,text/csv,video/mp4,audio/mpeg,audio/wav,image/png,image/jpeg,image/gif,image/webp
