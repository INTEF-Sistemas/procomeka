---
import { PreviewBannerIsland } from "../islands/layout/PreviewBannerIsland.tsx";
const isPreview = import.meta.env.PUBLIC_PREVIEW_MODE === "true";
---

{isPreview && (
	<PreviewBannerIsland client:load />
)}

<style>
	.preview-banner {
		position: fixed;
		bottom: 0;
		left: 0;
		right: 0;
		background: #1e40af;
		color: white;
		padding: 0.4rem 1rem;
		display: flex;
		align-items: center;
		gap: 1rem;
		font-size: 0.8rem;
		z-index: 9999;
		justify-content: center;
	}

	.preview-label {
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}

	.preview-role select {
		background: rgba(255, 255, 255, 0.2);
		color: white;
		border: 1px solid rgba(255, 255, 255, 0.4);
		border-radius: 3px;
		padding: 0.15rem 0.3rem;
		font-size: 0.8rem;
		cursor: pointer;
	}

	.preview-role select option {
		color: #1f2937;
		background: white;
	}

	.preview-banner button {
		background: rgba(255, 255, 255, 0.2);
		color: white;
		border: 1px solid rgba(255, 255, 255, 0.4);
		border-radius: 3px;
		padding: 0.15rem 0.5rem;
		font-size: 0.8rem;
		cursor: pointer;
	}

	.preview-banner button:hover {
		background: rgba(255, 255, 255, 0.3);
	}
</style>
