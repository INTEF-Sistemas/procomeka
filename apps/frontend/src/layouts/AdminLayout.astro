---
import Base from "./Base.astro";
import { BACKOFFICE_SECTIONS } from "../lib/backoffice-nav.ts";

interface Props {
	title: string;
	activeSection?: string;
}

const { title, activeSection = "dashboard" } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<Base title={title}>
	<div class="admin-shell">
		<button class="admin-nav-toggle" type="button" aria-expanded="false" aria-controls="admin-sidebar">
			<span class="admin-nav-toggle-icon" aria-hidden="true">|||</span>
			Menu
		</button>
		<aside id="admin-sidebar" class="admin-sidebar" aria-label="Navegacion del backoffice">
			<p class="admin-sidebar-title">Backoffice</p>
			<nav>
				<ul class="admin-nav-list">
					{BACKOFFICE_SECTIONS.map((section) => (
						<li data-nav-item data-min-role={section.minRole}>
							<a
								href={`${base}${section.href}`}
								data-nav-link
								data-section-id={section.id}
								class={section.id === activeSection ? "is-active" : undefined}
							>
								<span class="nav-icon" aria-hidden="true">{section.icon}</span>
								{section.label}
							</a>
						</li>
					))}
				</ul>
			</nav>
		</aside>
		<section class="admin-content">
			<slot />
		</section>
	</div>
</Base>

<script>
	import { getApiClient } from "../lib/get-api-client.ts";
	import { canAccessSection } from "../lib/backoffice-nav.ts";
	import { url } from "../lib/paths.ts";

	const toggle = document.querySelector(".admin-nav-toggle") as HTMLButtonElement | null;
	const sidebar = document.getElementById("admin-sidebar");
	toggle?.addEventListener("click", () => {
		const expanded = toggle.getAttribute("aria-expanded") === "true";
		toggle.setAttribute("aria-expanded", String(!expanded));
		sidebar?.classList.toggle("is-open", !expanded);
	});

	(async () => {
		const api = await getApiClient();
		const session = await api.getSession();
		const role = session?.user?.role ?? "reader";

		document.querySelectorAll("[data-nav-item]").forEach((item) => {
			const minRole = (item as HTMLElement).dataset.minRole as "author" | "curator" | "admin";
			if (!canAccessSection(role, minRole)) {
				(item as HTMLElement).style.display = "none";
			}
		});

		if (role === "reader") {
			window.location.href = url("login");
		}
	})().catch(() => {
		window.location.href = url("login");
	});
</script>

<!-- Scoped styles for the layout shell and sidebar -->
<style>
	.admin-shell {
		display: grid;
		grid-template-columns: 220px minmax(0, 1fr);
		gap: 1.5rem;
		align-items: start;
	}

	.admin-nav-toggle {
		display: none;
	}

	.admin-sidebar {
		border: 1px solid #d8dee9;
		border-radius: 14px;
		padding: 0.75rem;
		background: linear-gradient(180deg, #f7fafc 0%, #edf2f7 100%);
		position: sticky;
		top: 1rem;
	}

	.admin-sidebar-title {
		font-size: 0.72rem;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		color: #718096;
		margin-bottom: 0.6rem;
		padding-left: 0.5rem;
		font-weight: 700;
	}

	.admin-nav-list {
		list-style: none;
		display: flex;
		flex-direction: column;
		gap: 0.2rem;
	}

	.admin-nav-list a {
		display: flex;
		align-items: center;
		gap: 0.6rem;
		padding: 0.6rem 0.7rem;
		border-radius: 8px;
		text-decoration: none;
		color: #4a5568;
		font-weight: 500;
		font-size: 0.9rem;
		border-left: 3px solid transparent;
		transition: background 0.15s, color 0.15s, border-color 0.15s;
	}

	.admin-nav-list a:hover {
		background: #edf2f7;
		color: #1a365d;
	}

	.admin-nav-list a.is-active {
		background: #1a365d;
		color: white;
		border-left-color: #63b3ed;
		font-weight: 600;
	}

	.admin-nav-list a.is-active .nav-icon {
		background: rgba(255, 255, 255, 0.2);
		color: white;
	}

	.nav-icon {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 1.6rem;
		height: 1.6rem;
		border-radius: 6px;
		background: #e2e8f0;
		color: #4a5568;
		font-size: 0.72rem;
		font-weight: 700;
		flex-shrink: 0;
	}

	.admin-content {
		min-width: 0;
	}

	@media (max-width: 900px) {
		.admin-shell {
			grid-template-columns: 1fr;
		}

		.admin-nav-toggle {
			display: inline-flex;
			align-items: center;
			gap: 0.4rem;
			width: fit-content;
			padding: 0.55rem 0.85rem;
			border: 1px solid #cbd5e0;
			border-radius: 8px;
			background: white;
			font-weight: 600;
			font-size: 0.85rem;
			margin-bottom: 0.75rem;
			cursor: pointer;
		}

		.admin-nav-toggle-icon {
			font-size: 0.7rem;
			letter-spacing: -0.05em;
		}

		.admin-sidebar {
			display: none;
			position: static;
		}

		.admin-sidebar.is-open {
			display: block;
		}
	}
</style>

<!-- Global shared styles for all admin CRUD pages -->
<style is:global>
	/* ---- Page header ---- */
	.admin-page-head {
		display: flex;
		gap: 1rem;
		align-items: flex-end;
		justify-content: space-between;
		flex-wrap: wrap;
		margin-bottom: 1.25rem;
	}

	.admin-page-head h1 {
		font-size: 1.4rem;
		font-weight: 700;
		color: #1a202c;
		line-height: 1.2;
	}

	.admin-eyebrow {
		font-size: 0.7rem;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		color: #2b6cb0;
		font-weight: 700;
		margin-bottom: 0.15rem;
	}

	.admin-helper {
		color: #718096;
		font-size: 0.85rem;
		max-width: 60ch;
		margin-top: 0.25rem;
	}

	/* ---- Buttons ---- */
	.admin-btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 0.35rem;
		padding: 0.5rem 0.85rem;
		border-radius: 6px;
		border: 1px solid #cbd5e0;
		background: white;
		color: #2d3748;
		font-size: 0.82rem;
		font-weight: 600;
		cursor: pointer;
		text-decoration: none;
		line-height: 1.3;
		transition: background 0.12s, border-color 0.12s;
	}

	.admin-btn:hover {
		background: #f7fafc;
		border-color: #a0aec0;
	}

	.admin-btn:disabled {
		opacity: 0.5;
		cursor: not-allowed;
	}

	.admin-btn--primary {
		background: #1a365d;
		color: white;
		border-color: #1a365d;
	}

	.admin-btn--primary:hover {
		background: #2a4a7f;
		border-color: #2a4a7f;
	}

	.admin-btn--danger {
		background: #c53030;
		color: white;
		border-color: #c53030;
	}

	.admin-btn--danger:hover {
		background: #9b2c2c;
		border-color: #9b2c2c;
	}

	.admin-btn--ghost {
		background: transparent;
		border-color: transparent;
		color: #4a5568;
	}

	.admin-btn--ghost:hover {
		background: #edf2f7;
	}

	.admin-btn--sm {
		padding: 0.3rem 0.6rem;
		font-size: 0.78rem;
	}

	/* ---- Toolbar (search + filters) ---- */
	.admin-toolbar {
		display: flex;
		gap: 0.75rem;
		align-items: flex-end;
		flex-wrap: wrap;
		margin-bottom: 1rem;
		padding: 0.75rem;
		background: #f7fafc;
		border: 1px solid #e2e8f0;
		border-radius: 10px;
	}

	.admin-toolbar label {
		display: flex;
		flex-direction: column;
		gap: 0.15rem;
		font-size: 0.78rem;
		font-weight: 600;
		color: #4a5568;
	}

	.admin-toolbar input,
	.admin-toolbar select {
		padding: 0.45rem 0.6rem;
		border-radius: 6px;
		border: 1px solid #cbd5e0;
		font-size: 0.85rem;
		background: white;
	}

	.admin-toolbar input[type="search"] {
		min-width: 200px;
	}

	/* ---- Table wrapper ---- */
	.admin-table-wrap {
		overflow-x: auto;
		border: 1px solid #e2e8f0;
		border-radius: 10px;
		background: white;
	}

	.admin-table-wrap table {
		width: 100%;
		border-collapse: collapse;
		font-size: 0.88rem;
	}

	.admin-table-wrap thead {
		background: #f7fafc;
	}

	.admin-table-wrap th {
		padding: 0.65rem 0.85rem;
		text-align: left;
		font-size: 0.75rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.04em;
		color: #718096;
		border-bottom: 2px solid #e2e8f0;
		white-space: nowrap;
	}

	.admin-table-wrap td {
		padding: 0.65rem 0.85rem;
		border-bottom: 1px solid #edf2f7;
		color: #2d3748;
		vertical-align: middle;
	}

	.admin-table-wrap tbody tr:last-child td {
		border-bottom: none;
	}

	.admin-table-wrap tbody tr:hover {
		background: #f7fafc;
	}

	.admin-table-wrap .actions-cell {
		white-space: nowrap;
		display: flex;
		gap: 0.35rem;
	}

	/* ---- Status badges ---- */
	.admin-badge {
		display: inline-block;
		padding: 0.15rem 0.5rem;
		border-radius: 999px;
		font-size: 0.72rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.03em;
	}

	.admin-badge--draft {
		background: #fed7d7;
		color: #9b2c2c;
	}

	.admin-badge--review {
		background: #fefcbf;
		color: #975a16;
	}

	.admin-badge--published {
		background: #c6f6d5;
		color: #276749;
	}

	.admin-badge--archived {
		background: #e2e8f0;
		color: #4a5568;
	}

	.admin-badge--active {
		background: #c6f6d5;
		color: #276749;
	}

	.admin-badge--inactive {
		background: #fed7d7;
		color: #9b2c2c;
	}

	/* ---- Pagination ---- */
	.admin-pager {
		display: flex;
		gap: 0.75rem;
		align-items: center;
		justify-content: center;
		margin-top: 1rem;
		font-size: 0.85rem;
	}

	.admin-pager button {
		padding: 0.4rem 0.75rem;
		border: 1px solid #cbd5e0;
		border-radius: 6px;
		background: white;
		font-size: 0.82rem;
		font-weight: 600;
		cursor: pointer;
	}

	.admin-pager button:disabled {
		opacity: 0.4;
		cursor: not-allowed;
	}

	.admin-pager button:hover:not(:disabled) {
		background: #edf2f7;
	}

	.admin-pager-label {
		color: #718096;
		font-weight: 500;
	}

	/* ---- List status (aria-live region) ---- */
	.admin-list-status {
		color: #718096;
		font-size: 0.82rem;
		margin-bottom: 0.5rem;
	}

	/* ---- Form card (quick create) ---- */
	.admin-form-card {
		border: 1px solid #e2e8f0;
		border-radius: 10px;
		background: white;
		padding: 1rem 1.25rem;
		margin-bottom: 1rem;
	}

	.admin-form-card h2 {
		font-size: 0.95rem;
		font-weight: 700;
		margin-bottom: 0.75rem;
		color: #2d3748;
	}

	.admin-form-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
		gap: 0.65rem;
	}

	.admin-form-grid .full {
		grid-column: 1 / -1;
	}

	.admin-form-card label {
		display: flex;
		flex-direction: column;
		gap: 0.15rem;
		font-size: 0.78rem;
		font-weight: 600;
		color: #4a5568;
	}

	.admin-form-card input,
	.admin-form-card textarea,
	.admin-form-card select {
		padding: 0.45rem 0.6rem;
		border-radius: 6px;
		border: 1px solid #cbd5e0;
		font-size: 0.85rem;
	}

	.admin-form-card textarea {
		resize: vertical;
	}

	.admin-form-card .checkbox-label {
		flex-direction: row;
		align-items: center;
		gap: 0.4rem;
		margin-top: 0.25rem;
	}

	.admin-form-actions {
		margin-top: 0.75rem;
	}

	/* ---- Confirmation dialog ---- */
	.admin-confirm-dialog {
		border: none;
		border-radius: 12px;
		padding: 1.5rem;
		max-width: 400px;
		width: 90vw;
		box-shadow: 0 8px 30px rgba(0, 0, 0, 0.15);
	}

	.admin-confirm-dialog::backdrop {
		background: rgba(0, 0, 0, 0.4);
	}

	.admin-confirm-dialog p {
		margin-bottom: 1.25rem;
		font-size: 0.95rem;
		color: #2d3748;
		line-height: 1.5;
	}

	.admin-dialog-actions {
		display: flex;
		gap: 0.5rem;
		justify-content: flex-end;
	}

	/* ---- Edit dialog (modal) ---- */
	.admin-edit-dialog {
		border: none;
		border-radius: 12px;
		padding: 1.5rem;
		max-width: 520px;
		width: 90vw;
		box-shadow: 0 8px 30px rgba(0, 0, 0, 0.15);
	}

	.admin-edit-dialog::backdrop {
		background: rgba(0, 0, 0, 0.4);
	}

	.admin-edit-dialog h2 {
		font-size: 1.05rem;
		font-weight: 700;
		margin-bottom: 1rem;
		color: #1a202c;
	}

	.admin-edit-dialog label {
		display: flex;
		flex-direction: column;
		gap: 0.15rem;
		font-size: 0.82rem;
		font-weight: 600;
		color: #4a5568;
		margin-bottom: 0.65rem;
	}

	.admin-edit-dialog input,
	.admin-edit-dialog textarea,
	.admin-edit-dialog select {
		padding: 0.45rem 0.6rem;
		border-radius: 6px;
		border: 1px solid #cbd5e0;
		font-size: 0.88rem;
		width: 100%;
		box-sizing: border-box;
	}

	.admin-edit-dialog textarea {
		resize: vertical;
	}

	.admin-edit-dialog .checkbox-label {
		flex-direction: row;
		align-items: center;
		gap: 0.4rem;
	}

	.admin-edit-dialog .admin-dialog-actions {
		margin-top: 1rem;
	}

	.admin-edit-dialog .dialog-error {
		color: #c53030;
		font-size: 0.82rem;
		margin-top: 0.5rem;
	}

	/* ---- Inline select in tables ---- */
	.admin-table-wrap select {
		padding: 0.3rem 0.45rem;
		border-radius: 5px;
		border: 1px solid #cbd5e0;
		font-size: 0.82rem;
		background: white;
	}

	/* ---- Empty state ---- */
	.admin-empty-row td {
		text-align: center;
		color: #a0aec0;
		padding: 2rem 1rem;
		font-style: italic;
	}

	/* ---- Feedback messages ---- */
	.admin-feedback {
		padding: 0.5rem 0.75rem;
		border-radius: 6px;
		font-size: 0.85rem;
		margin-bottom: 0.75rem;
	}

	.admin-feedback--success {
		background: #c6f6d5;
		color: #276749;
	}

	.admin-feedback--error {
		background: #fed7d7;
		color: #9b2c2c;
	}

	/* ---- Responsive ---- */
	@media (max-width: 700px) {
		.admin-toolbar {
			flex-direction: column;
			align-items: stretch;
		}

		.admin-toolbar input[type="search"] {
			min-width: auto;
		}

		.admin-form-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
