---
import { AdminNavIsland } from "../islands/layout/AdminNavIsland.tsx";
import Base from "./Base.astro";

interface Props {
	title: string;
	activeSection?: string;
}

const { title, activeSection = "dashboard" } = Astro.props;
---

<Base title={title}>
	<style is:global>
		.admin-shell {
			display: grid;
			grid-template-columns: 220px minmax(0, 1fr);
			gap: 1.5rem;
			align-items: start;
		}

		.admin-shell .admin-nav-toggle {
			display: none;
		}

		.admin-shell .admin-sidebar {
			border: 1px solid #d8dee9;
			border-radius: 14px;
			padding: 0.75rem;
			background: linear-gradient(180deg, #f7fafc 0%, #edf2f7 100%);
			position: sticky;
			top: 1rem;
		}

		.admin-shell .admin-sidebar-title {
			font-size: 0.72rem;
			text-transform: uppercase;
			letter-spacing: 0.1em;
			color: #718096;
			margin-bottom: 0.6rem;
			padding-left: 0.5rem;
			font-weight: 700;
		}

		.admin-shell .admin-nav-list {
			list-style: none;
			display: flex;
			flex-direction: column;
			gap: 0.2rem;
		}

		.admin-shell .admin-nav-list a {
			display: flex;
			align-items: center;
			gap: 0.6rem;
			padding: 0.6rem 0.7rem;
			border-radius: 8px;
			text-decoration: none;
			color: #4a5568;
			font-weight: 500;
			font-size: 0.9rem;
			border-left: 3px solid transparent;
			transition: background 0.15s, color 0.15s, border-color 0.15s;
		}

		.admin-shell .admin-nav-list a:hover {
			background: #edf2f7;
			color: #1a365d;
		}

		.admin-shell .admin-nav-list a.is-active {
			background: #1a365d;
			color: white;
			border-left-color: #63b3ed;
			font-weight: 600;
		}

		.admin-shell .admin-nav-list a.is-active .nav-icon {
			background: rgba(255, 255, 255, 0.2);
			color: white;
		}

		.admin-shell .nav-icon {
			display: inline-flex;
			align-items: center;
			justify-content: center;
			width: 1.6rem;
			height: 1.6rem;
			border-radius: 6px;
			background: #e2e8f0;
			color: #4a5568;
			font-size: 0.72rem;
			font-weight: 700;
			flex-shrink: 0;
		}

		.admin-shell .admin-content {
			min-width: 0;
		}

		.admin-page-head {
			display: flex;
			gap: 1rem;
			align-items: flex-end;
			justify-content: space-between;
			flex-wrap: wrap;
			margin-bottom: 1.25rem;
		}

		.admin-page-head h1 {
			font-size: 1.4rem;
			font-weight: 700;
			color: #1a202c;
			line-height: 1.2;
		}

		.admin-eyebrow {
			font-size: 0.7rem;
			text-transform: uppercase;
			letter-spacing: 0.1em;
			color: #2b6cb0;
			font-weight: 700;
			margin-bottom: 0.15rem;
		}

		.admin-helper {
			color: #718096;
			font-size: 0.85rem;
			max-width: 60ch;
			margin-top: 0.25rem;
		}

		.admin-btn {
			display: inline-flex;
			align-items: center;
			justify-content: center;
			gap: 0.35rem;
			padding: 0.5rem 0.85rem;
			border-radius: 6px;
			border: 1px solid #cbd5e0;
			background: white;
			color: #2d3748;
			font-size: 0.82rem;
			font-weight: 600;
			cursor: pointer;
			text-decoration: none;
			line-height: 1.3;
			transition: background 0.12s, border-color 0.12s;
		}

		.admin-btn:hover {
			background: #f7fafc;
			border-color: #a0aec0;
		}

		.admin-btn:disabled {
			opacity: 0.5;
			cursor: not-allowed;
		}

		.admin-btn--primary {
			background: #1a365d;
			color: white;
			border-color: #1a365d;
		}

		.admin-btn--primary:hover {
			background: #2a4a7f;
			border-color: #2a4a7f;
		}

		.admin-btn--danger {
			background: #c53030;
			color: white;
			border-color: #c53030;
		}

		.admin-btn--danger:hover {
			background: #9b2c2c;
			border-color: #9b2c2c;
		}

		.admin-btn--ghost {
			background: transparent;
			border-color: transparent;
			color: #4a5568;
		}

		.admin-btn--ghost:hover {
			background: #edf2f7;
		}

		.admin-btn--sm {
			padding: 0.3rem 0.6rem;
			font-size: 0.78rem;
		}

		.admin-toolbar {
			display: flex;
			gap: 0.75rem;
			align-items: flex-end;
			flex-wrap: wrap;
			margin-bottom: 1rem;
			padding: 0.75rem;
			background: #f7fafc;
			border: 1px solid #e2e8f0;
			border-radius: 10px;
		}

		.admin-toolbar label {
			display: flex;
			flex-direction: column;
			gap: 0.25rem;
			font-size: 0.78rem;
			font-weight: 600;
			color: #4a5568;
		}

		.admin-toolbar input[type="search"],
		.admin-toolbar select {
			min-width: 180px;
			padding: 0.5rem 0.65rem;
			border-radius: 7px;
			border: 1px solid #cbd5e0;
			background: white;
			font-size: 0.88rem;
		}

		.admin-form-card {
			background: white;
			border: 1px solid #e2e8f0;
			border-radius: 12px;
			padding: 1rem;
			margin-bottom: 1rem;
		}

		.admin-form-card h2 {
			font-size: 1rem;
			margin-bottom: 0.85rem;
			color: #1a202c;
		}

		.admin-form-grid {
			display: grid;
			grid-template-columns: repeat(2, minmax(0, 1fr));
			gap: 0.85rem;
		}

		.admin-form-grid .full {
			grid-column: 1 / -1;
		}

		.admin-form-grid label,
		.admin-edit-dialog label {
			display: flex;
			flex-direction: column;
			gap: 0.25rem;
			font-size: 0.8rem;
			font-weight: 600;
			color: #4a5568;
		}

		.admin-form-grid input,
		.admin-form-grid textarea,
		.admin-form-grid select,
		.admin-edit-dialog input,
		.admin-edit-dialog textarea,
		.admin-edit-dialog select {
			width: 100%;
			padding: 0.55rem 0.7rem;
			border-radius: 7px;
			border: 1px solid #cbd5e0;
			background: white;
			font-size: 0.9rem;
		}

		.checkbox-label {
			flex-direction: row !important;
			align-items: center;
			gap: 0.5rem;
		}

		.checkbox-label input {
			width: auto;
		}

		.admin-form-actions,
		.admin-dialog-actions {
			display: flex;
			gap: 0.5rem;
			flex-wrap: wrap;
			margin-top: 1rem;
		}

		.admin-list-status {
			font-size: 0.84rem;
			color: #718096;
			margin-bottom: 0.75rem;
		}

		.admin-table-wrap {
			overflow-x: auto;
			border: 1px solid #e2e8f0;
			border-radius: 12px;
			background: white;
		}

		.admin-table-wrap table {
			width: 100%;
			border-collapse: collapse;
		}

		.admin-table-wrap th,
		.admin-table-wrap td {
			padding: 0.8rem 0.9rem;
			text-align: left;
			border-bottom: 1px solid #edf2f7;
			vertical-align: middle;
			font-size: 0.88rem;
		}

		.admin-table-wrap thead th {
			font-size: 0.76rem;
			text-transform: uppercase;
			letter-spacing: 0.06em;
			color: #718096;
			background: #f7fafc;
		}

		.actions-cell {
			display: flex;
			gap: 0.45rem;
			flex-wrap: wrap;
		}

		.admin-pager {
			display: flex;
			align-items: center;
			justify-content: flex-end;
			gap: 0.6rem;
			margin-top: 0.85rem;
		}

		.admin-pager button {
			padding: 0.4rem 0.7rem;
			border-radius: 6px;
			border: 1px solid #cbd5e0;
			background: white;
			cursor: pointer;
		}

		.admin-pager button:disabled {
			opacity: 0.5;
			cursor: not-allowed;
		}

		.admin-pager-label {
			font-size: 0.84rem;
			color: #4a5568;
		}

		.admin-badge {
			display: inline-flex;
			align-items: center;
			padding: 0.2rem 0.5rem;
			border-radius: 999px;
			font-size: 0.73rem;
			font-weight: 700;
			text-transform: uppercase;
			letter-spacing: 0.03em;
		}

		.admin-badge--draft {
			background: #fff5f5;
			color: #c53030;
		}

		.admin-badge--review {
			background: #fefcbf;
			color: #975a16;
		}

		.admin-badge--published {
			background: #c6f6d5;
			color: #276749;
		}

		.admin-badge--archived {
			background: #edf2f7;
			color: #4a5568;
		}

		.admin-modal-backdrop {
			position: fixed;
			inset: 0;
			background: rgba(15, 23, 42, 0.45);
			display: flex;
			align-items: center;
			justify-content: center;
			padding: 1rem;
			z-index: 1000;
		}

		.admin-modal-card,
		.admin-edit-dialog {
			background: white;
			border-radius: 12px;
			padding: 1.5rem;
			max-width: 520px;
			width: 90vw;
			margin: 0;
			box-shadow: 0 8px 30px rgba(0, 0, 0, 0.15);
			max-height: calc(100vh - 2rem);
			overflow: auto;
		}

		.admin-edit-dialog h2 {
			font-size: 1.05rem;
			font-weight: 700;
			margin-bottom: 1rem;
			color: #1a202c;
		}

		.admin-edit-dialog .checkbox-label {
			flex-direction: row;
			align-items: center;
			gap: 0.4rem;
		}

		.admin-edit-dialog .admin-dialog-actions {
			margin-top: 1rem;
		}

		.admin-edit-dialog .dialog-error {
			color: #c53030;
			font-size: 0.82rem;
			margin-top: 0.5rem;
		}

		.admin-table-wrap select {
			padding: 0.3rem 0.45rem;
			border-radius: 5px;
			border: 1px solid #cbd5e0;
			font-size: 0.82rem;
			background: white;
		}

		.admin-empty-row td {
			text-align: center;
			color: #a0aec0;
			padding: 2rem 1rem;
			font-style: italic;
		}

		.admin-feedback {
			padding: 0.5rem 0.75rem;
			border-radius: 6px;
			font-size: 0.85rem;
			margin-bottom: 0.75rem;
		}

		.admin-feedback--success {
			background: #c6f6d5;
			color: #276749;
		}

		.admin-feedback--error {
			background: #fed7d7;
			color: #9b2c2c;
		}

		.sr-only {
			position: absolute;
			width: 1px;
			height: 1px;
			padding: 0;
			margin: -1px;
			overflow: hidden;
			clip: rect(0, 0, 0, 0);
			white-space: nowrap;
			border: 0;
		}

		@media (max-width: 900px) {
			.admin-shell {
				grid-template-columns: 1fr;
			}

			.admin-shell .admin-nav-toggle {
				display: inline-flex;
				align-items: center;
				gap: 0.4rem;
				width: fit-content;
				padding: 0.55rem 0.85rem;
				border: 1px solid #cbd5e0;
				border-radius: 8px;
				background: white;
				font-weight: 600;
				font-size: 0.85rem;
				margin-bottom: 0.75rem;
				cursor: pointer;
			}

			.admin-shell .admin-nav-toggle-icon {
				font-size: 0.7rem;
				letter-spacing: -0.05em;
			}

			.admin-shell .admin-sidebar {
				display: none;
				position: static;
			}

			.admin-shell .admin-sidebar.is-open {
				display: block;
			}
		}

		@media (max-width: 700px) {
			.admin-toolbar {
				flex-direction: column;
				align-items: stretch;
			}

			.admin-toolbar input[type="search"] {
				min-width: auto;
			}

			.admin-form-grid {
				grid-template-columns: 1fr;
			}
		}
	</style>

	<div class="admin-shell">
		<AdminNavIsland client:load activeSection={activeSection} />
		<section class="admin-content">
			<slot />
		</section>
	</div>
</Base>
