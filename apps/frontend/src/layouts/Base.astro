---
import { BaseNavIsland } from "../islands/layout/BaseNavIsland.tsx";
import PreviewBanner from "../components/PreviewBanner.astro";

interface Props {
	title: string;
}

const { title } = Astro.props;
const base = import.meta.env.BASE_URL;
const isPreview = import.meta.env.PUBLIC_PREVIEW_MODE === "true";
const hasHeaderCenter = Astro.slots.has("header-center");
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<title>{title} — Procomeka</title>
		<script define:vars={{ base, isPreview }}>
			window.__BASE_URL__ = base;
			window.__PREVIEW_MODE__ = isPreview;
		</script>
	</head>
	<body class={isPreview ? "has-preview-banner" : ""}>
		<header>
			<nav class={hasHeaderCenter ? "nav-with-center" : ""}>
				<a href={base} class="brand">Procomeka</a>
				{hasHeaderCenter && (
					<div class="nav-center">
						<slot name="header-center" />
					</div>
				)}
				<BaseNavIsland client:load />
			</nav>
		</header>
		<main>
			<slot />
		</main>
		<footer>
			<p>Plataforma de recursos educativos abiertos</p>
		</footer>
		<PreviewBanner />
	</body>
</html>

<style is:global>
	* {
		margin: 0;
		padding: 0;
		box-sizing: border-box;
	}

	body {
		font-family: system-ui, -apple-system, sans-serif;
		line-height: 1.6;
		color: #1f2937;
	}

	body.has-preview-banner {
		padding-bottom: 2.5rem;
	}

	header {
		border-bottom: 1px solid #e5e7eb;
		padding: 0.75rem 1.5rem;
	}

	nav {
		display: flex;
		justify-content: space-between;
		align-items: center;
		max-width: 1200px;
		margin: 0 auto;
	}

	nav.nav-with-center {
		gap: 1rem;
	}

	.brand {
		font-weight: 700;
		font-size: 1.1rem;
		text-decoration: none;
		color: #1f2937;
		white-space: nowrap;
	}

	.nav-center {
		flex: 1;
		max-width: 480px;
	}

	.nav-links {
		display: flex;
		gap: 1rem;
		white-space: nowrap;
	}

	.nav-links a {
		color: #4b5563;
		text-decoration: none;
		font-size: 0.9rem;
	}

	.nav-links a:hover {
		color: #1a56db;
	}

	main {
		max-width: 1200px;
		margin: 0 auto;
		padding: 1.5rem;
	}

	footer {
		border-top: 1px solid #e5e7eb;
		padding: 1rem 1.5rem;
		text-align: center;
		color: #6b7280;
		font-size: 0.85rem;
		margin-top: 3rem;
	}

	@media (max-width: 768px) {
		nav.nav-with-center {
			flex-wrap: wrap;
		}

		.nav-center {
			order: 3;
			max-width: 100%;
			flex-basis: 100%;
		}
	}
</style>
