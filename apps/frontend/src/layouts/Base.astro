---
interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<title>{title} — Procomeka</title>
	</head>
	<body>
		<header>
			<nav>
				<a href="/">Procomeka</a>
			</nav>
		</header>
		<main>
			<slot />
		</main>
		<footer>
			<p>Plataforma de recursos educativos abiertos</p>
		</footer>
	</body>
</html>
