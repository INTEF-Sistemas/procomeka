---
import AdminLayout from "../../../layouts/AdminLayout.astro";
---

<AdminLayout title="Categorias" activeSection="taxonomies">
	<section class="admin-page-head">
		<div>
			<p class="admin-eyebrow">Gestion</p>
			<h1>Categorias y taxonomias</h1>
		</div>
	</section>

	<section class="admin-form-card">
		<h2>Nueva categoria</h2>
		<form id="create-form">
			<div class="admin-form-grid">
				<label>
					Nombre
					<input id="create-name" required />
				</label>
				<label>
					Slug (opcional)
					<input id="create-slug" placeholder="se-genera-automaticamente" />
				</label>
				<label>
					Tipo
					<select id="create-type">
						<option value="category">Categoria</option>
						<option value="tag">Etiqueta</option>
						<option value="subject">Materia</option>
						<option value="level">Nivel educativo</option>
						<option value="resource-type">Tipo de recurso</option>
						<option value="language">Idioma</option>
						<option value="license">Licencia</option>
					</select>
				</label>
			</div>
			<div class="admin-form-actions">
				<button type="submit" class="admin-btn admin-btn--primary">Crear categoria</button>
			</div>
		</form>
		<div id="create-feedback" role="status" aria-live="polite"></div>
	</section>

	<section class="admin-toolbar">
		<label>
			Busqueda
			<input id="search" type="search" placeholder="Nombre o slug" />
		</label>
		<label>
			Tipo
			<select id="type-filter">
				<option value="">Todos los tipos</option>
				<option value="category">Categoria</option>
				<option value="tag">Etiqueta</option>
				<option value="subject">Materia</option>
				<option value="level">Nivel educativo</option>
				<option value="resource-type">Tipo de recurso</option>
				<option value="language">Idioma</option>
				<option value="license">Licencia</option>
			</select>
		</label>
		<button id="apply-filters" type="button" class="admin-btn">Aplicar</button>
	</section>

	<div id="list-status" class="admin-list-status" aria-live="polite"></div>

	<div class="admin-table-wrap">
		<table>
			<thead>
				<tr>
					<th>Nombre</th>
					<th>Tipo</th>
					<th>Slug</th>
					<th>Parent</th>
					<th>Actualizado</th>
					<th>Acciones</th>
				</tr>
			</thead>
			<tbody id="taxonomy-body"></tbody>
		</table>
	</div>

	<div class="admin-pager">
		<button id="prev-page" type="button" disabled>Anterior</button>
		<span id="page-label" class="admin-pager-label">Pagina 1</span>
		<button id="next-page" type="button" disabled>Siguiente</button>
	</div>

	<dialog id="confirm-dialog" class="admin-confirm-dialog">
		<form method="dialog">
			<p id="confirm-message">Seguro que deseas eliminar esta categoria?</p>
			<div class="admin-dialog-actions">
				<button value="cancel" class="admin-btn">Cancelar</button>
				<button value="confirm" class="admin-btn admin-btn--danger">Eliminar</button>
			</div>
		</form>
	</dialog>

	<dialog id="edit-dialog" class="admin-edit-dialog">
		<h2>Editar categoria</h2>
		<form id="edit-form">
			<label>
				Nombre
				<input id="edit-name" required />
			</label>
			<label>
				Slug
				<input id="edit-slug" />
			</label>
			<label>
				Tipo
				<select id="edit-type">
					<option value="category">Categoria</option>
					<option value="tag">Etiqueta</option>
					<option value="subject">Materia</option>
					<option value="level">Nivel educativo</option>
					<option value="resource-type">Tipo de recurso</option>
					<option value="language">Idioma</option>
					<option value="license">Licencia</option>
				</select>
			</label>
			<div id="edit-error" class="dialog-error" role="alert" aria-live="polite"></div>
			<div class="admin-dialog-actions">
				<button type="button" id="edit-cancel" class="admin-btn">Cancelar</button>
				<button type="submit" class="admin-btn admin-btn--primary">Guardar</button>
			</div>
		</form>
	</dialog>
</AdminLayout>

<script>
	import { getApiClient } from "../../../lib/get-api-client.ts";
	import { url } from "../../../lib/paths.ts";

	const tbody = document.getElementById("taxonomy-body") as HTMLTableSectionElement;
	const statusBox = document.getElementById("list-status") as HTMLDivElement;
	const pageLabel = document.getElementById("page-label") as HTMLSpanElement;
	const prevBtn = document.getElementById("prev-page") as HTMLButtonElement;
	const nextBtn = document.getElementById("next-page") as HTMLButtonElement;
	const searchInput = document.getElementById("search") as HTMLInputElement;
	const typeFilter = document.getElementById("type-filter") as HTMLSelectElement;
	const createForm = document.getElementById("create-form") as HTMLFormElement;
	const createFeedback = document.getElementById("create-feedback") as HTMLDivElement;
	const confirmDialog = document.getElementById("confirm-dialog") as HTMLDialogElement;
	const confirmMessage = document.getElementById("confirm-message") as HTMLParagraphElement;
	const editDialog = document.getElementById("edit-dialog") as HTMLDialogElement;
	const editForm = document.getElementById("edit-form") as HTMLFormElement;
	const editError = document.getElementById("edit-error") as HTMLDivElement;

	let offset = 0;
	const limit = 20;
	let total = 0;
	let pendingDeleteId: string | null = null;
	let editingId: string | null = null;

	function escapeHtml(str: string): string {
		const d = document.createElement("div");
		d.textContent = str;
		return d.innerHTML;
	}

	async function loadTaxonomies() {
		statusBox.textContent = "Cargando categorias...";
		const api = await getApiClient();
		const result = await api.listTaxonomies({
			q: searchInput.value || undefined,
			type: typeFilter.value || undefined,
			limit,
			offset,
		});
		total = result.total;

		const pager = document.querySelector(".admin-pager") as HTMLElement;
		if (total <= limit) {
			pager.hidden = true;
		} else {
			pager.hidden = false;
			const page = Math.floor(offset / limit) + 1;
			const totalPages = Math.ceil(total / limit);
			pageLabel.textContent = `Pagina ${page} de ${totalPages}`;
			prevBtn.disabled = offset === 0;
			nextBtn.disabled = offset + limit >= total;
		}

		if (!result.data.length) {
			tbody.innerHTML = `<tr class="admin-empty-row"><td colspan="6">No hay categorias para los filtros actuales.</td></tr>`;
			statusBox.textContent = `${total} categorias encontradas`;
			return;
		}

		tbody.innerHTML = result.data.map((t) => `
			<tr>
				<td>${escapeHtml(t.name)}</td>
				<td><span class="admin-badge">${escapeHtml(t.type)}</span></td>
				<td><code>${escapeHtml(t.slug)}</code></td>
				<td>${t.parentId ? escapeHtml(t.parentId) : "-"}</td>
				<td>${t.updatedAt ? new Date(t.updatedAt).toLocaleDateString("es-ES") : "-"}</td>
				<td class="actions-cell">
					<button type="button" class="admin-btn admin-btn--sm" data-edit-id="${t.id}">Editar</button>
					<button type="button" class="admin-btn admin-btn--sm admin-btn--danger" data-delete-id="${t.id}" data-delete-title="${escapeHtml(t.name)}">Eliminar</button>
				</td>
			</tr>
		`).join("");

		tbody.querySelectorAll("[data-edit-id]").forEach((button) => {
			button.addEventListener("click", async () => {
				const id = (button as HTMLButtonElement).dataset.editId!;
				editingId = id;
				const api = await getApiClient();
				const tax = await api.getTaxonomyById(id);
				if (!tax) return;
				(document.getElementById("edit-name") as HTMLInputElement).value = tax.name;
				(document.getElementById("edit-slug") as HTMLInputElement).value = tax.slug;
				(document.getElementById("edit-type") as HTMLSelectElement).value = tax.type;
				editError.textContent = "";
				editDialog.showModal();
			});
		});

		tbody.querySelectorAll("[data-delete-id]").forEach((button) => {
			button.addEventListener("click", () => {
				const btn = button as HTMLButtonElement;
				pendingDeleteId = btn.dataset.deleteId ?? null;
				const title = btn.dataset.deleteTitle ?? "esta categoria";
				confirmMessage.textContent = `Seguro que deseas eliminar "${title}"?`;
				confirmDialog.showModal();
			});
		});

		statusBox.textContent = `${total} categorias encontradas`;
	}

	// Create form
	createForm.addEventListener("submit", async (e) => {
		e.preventDefault();
		createFeedback.textContent = "";
		createFeedback.className = "";
		try {
			const api = await getApiClient();
			await api.createTaxonomy({
				name: (document.getElementById("create-name") as HTMLInputElement).value,
				slug: (document.getElementById("create-slug") as HTMLInputElement).value || undefined,
				type: (document.getElementById("create-type") as HTMLSelectElement).value || "category",
			});
			createForm.reset();
			createFeedback.textContent = "Categoria creada.";
			createFeedback.className = "admin-feedback admin-feedback--success";
			offset = 0;
			loadTaxonomies();
		} catch {
			createFeedback.textContent = "Error al crear la categoria.";
			createFeedback.className = "admin-feedback admin-feedback--error";
		}
	});

	// Edit form
	editForm.addEventListener("submit", async (e) => {
		e.preventDefault();
		if (!editingId) return;
		editError.textContent = "";
		try {
			const api = await getApiClient();
			const result = await api.updateTaxonomy(editingId, {
				name: (document.getElementById("edit-name") as HTMLInputElement).value,
				slug: (document.getElementById("edit-slug") as HTMLInputElement).value,
				type: (document.getElementById("edit-type") as HTMLSelectElement).value,
			});
			if (!result.ok) {
				editError.textContent = result.error ?? "Error al guardar.";
				return;
			}
			editDialog.close();
			editingId = null;
			loadTaxonomies();
		} catch {
			editError.textContent = "Error de conexion.";
		}
	});

	document.getElementById("edit-cancel")?.addEventListener("click", () => {
		editDialog.close();
		editingId = null;
	});

	// Delete confirmation
	confirmDialog.addEventListener("close", async () => {
		if (confirmDialog.returnValue === "confirm" && pendingDeleteId) {
			const api = await getApiClient();
			await api.deleteTaxonomy(pendingDeleteId);
			pendingDeleteId = null;
			loadTaxonomies();
		}
		pendingDeleteId = null;
	});

	// Filters
	document.getElementById("apply-filters")?.addEventListener("click", () => {
		offset = 0;
		loadTaxonomies();
	});

	searchInput.addEventListener("keydown", (e) => {
		if (e.key === "Enter") {
			offset = 0;
			loadTaxonomies();
		}
	});

	// Pagination
	prevBtn.addEventListener("click", () => {
		offset = Math.max(0, offset - limit);
		loadTaxonomies();
	});

	nextBtn.addEventListener("click", () => {
		offset += limit;
		loadTaxonomies();
	});

	loadTaxonomies().catch(() => {
		window.location.href = url("login");
	});
</script>
