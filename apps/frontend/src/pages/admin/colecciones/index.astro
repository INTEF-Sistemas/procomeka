---
import AdminLayout from "../../../layouts/AdminLayout.astro";
---

<AdminLayout title="Colecciones" activeSection="collections">
	<section class="admin-page-head">
		<div>
			<p class="admin-eyebrow">Gestion</p>
			<h1>Colecciones</h1>
		</div>
	</section>

	<section class="admin-form-card">
		<h2>Nueva coleccion</h2>
		<form id="create-form">
			<div class="admin-form-grid">
				<label>
					Titulo
					<input id="create-title" required />
				</label>
				<label class="full">
					Descripcion
					<textarea id="create-description" rows="2" required></textarea>
				</label>
				<label class="checkbox-label">
					<input id="create-ordered" type="checkbox" /> Orden fija
				</label>
			</div>
			<div class="admin-form-actions">
				<button type="submit" class="admin-btn admin-btn--primary">Crear coleccion</button>
			</div>
		</form>
		<div id="create-feedback" role="status" aria-live="polite"></div>
	</section>

	<section class="admin-toolbar">
		<label>
			Busqueda
			<input id="search" type="search" placeholder="Titulo o descripcion" />
		</label>
		<button id="apply-filters" type="button" class="admin-btn">Aplicar</button>
	</section>

	<div id="list-status" class="admin-list-status" aria-live="polite"></div>

	<div class="admin-table-wrap">
		<table>
			<thead>
				<tr>
					<th>Titulo</th>
					<th>Estado</th>
					<th>Descripcion</th>
					<th>Orden fija</th>
					<th>Actualizado</th>
					<th>Acciones</th>
				</tr>
			</thead>
			<tbody id="collections-body"></tbody>
		</table>
	</div>

	<div class="admin-pager">
		<button id="prev-page" type="button" disabled>Anterior</button>
		<span id="page-label" class="admin-pager-label">Pagina 1</span>
		<button id="next-page" type="button" disabled>Siguiente</button>
	</div>

	<dialog id="confirm-dialog" class="admin-confirm-dialog">
		<form method="dialog">
			<p id="confirm-message">Seguro que deseas eliminar esta coleccion?</p>
			<div class="admin-dialog-actions">
				<button value="cancel" class="admin-btn">Cancelar</button>
				<button value="confirm" class="admin-btn admin-btn--danger">Eliminar</button>
			</div>
		</form>
	</dialog>

	<dialog id="edit-dialog" class="admin-edit-dialog">
		<h2>Editar coleccion</h2>
		<form id="edit-form">
			<label>
				Titulo
				<input id="edit-title" required />
			</label>
			<label>
				Descripcion
				<textarea id="edit-description" rows="3" required></textarea>
			</label>
			<label>
				Estado
				<select id="edit-status">
					<option value="draft">Borrador</option>
					<option value="review">En revision</option>
					<option value="published">Publicado</option>
					<option value="archived">Archivado</option>
				</select>
			</label>
			<label class="checkbox-label">
				<input id="edit-ordered" type="checkbox" /> Orden fija
			</label>
			<div id="edit-error" class="dialog-error" role="alert" aria-live="polite"></div>
			<div class="admin-dialog-actions">
				<button type="button" id="edit-cancel" class="admin-btn">Cancelar</button>
				<button type="submit" class="admin-btn admin-btn--primary">Guardar</button>
			</div>
		</form>
	</dialog>
</AdminLayout>

<script>
	import { getApiClient } from "../../../lib/get-api-client.ts";
	import { url } from "../../../lib/paths.ts";

	const tbody = document.getElementById("collections-body") as HTMLTableSectionElement;
	const statusBox = document.getElementById("list-status") as HTMLDivElement;
	const pageLabel = document.getElementById("page-label") as HTMLSpanElement;
	const prevBtn = document.getElementById("prev-page") as HTMLButtonElement;
	const nextBtn = document.getElementById("next-page") as HTMLButtonElement;
	const searchInput = document.getElementById("search") as HTMLInputElement;
	const createForm = document.getElementById("create-form") as HTMLFormElement;
	const createFeedback = document.getElementById("create-feedback") as HTMLDivElement;
	const confirmDialog = document.getElementById("confirm-dialog") as HTMLDialogElement;
	const confirmMessage = document.getElementById("confirm-message") as HTMLParagraphElement;
	const editDialog = document.getElementById("edit-dialog") as HTMLDialogElement;
	const editForm = document.getElementById("edit-form") as HTMLFormElement;
	const editError = document.getElementById("edit-error") as HTMLDivElement;

	let offset = 0;
	const limit = 20;
	let total = 0;
	let pendingDeleteId: string | null = null;
	let editingId: string | null = null;

	function badgeClass(status: string): string {
		const map: Record<string, string> = {
			draft: "admin-badge--draft",
			review: "admin-badge--review",
			published: "admin-badge--published",
			archived: "admin-badge--archived",
		};
		return map[status] ?? "";
	}

	function statusLabel(status: string): string {
		const map: Record<string, string> = {
			draft: "Borrador",
			review: "En revision",
			published: "Publicado",
			archived: "Archivado",
		};
		return map[status] ?? status;
	}

	function escapeHtml(str: string): string {
		const d = document.createElement("div");
		d.textContent = str;
		return d.innerHTML;
	}

	function truncate(str: string, len: number): string {
		if (str.length <= len) return str;
		return str.slice(0, len) + "...";
	}

	async function loadCollections() {
		statusBox.textContent = "Cargando colecciones...";
		const api = await getApiClient();
		const result = await api.listCollections({
			q: searchInput.value || undefined,
			limit,
			offset,
		});
		total = result.total;

		const pager = document.querySelector(".admin-pager") as HTMLElement;
		if (total <= limit) {
			pager.hidden = true;
		} else {
			pager.hidden = false;
			const page = Math.floor(offset / limit) + 1;
			const totalPages = Math.ceil(total / limit);
			pageLabel.textContent = `Pagina ${page} de ${totalPages}`;
			prevBtn.disabled = offset === 0;
			nextBtn.disabled = offset + limit >= total;
		}

		if (!result.data.length) {
			tbody.innerHTML = `<tr class="admin-empty-row"><td colspan="6">No hay colecciones.</td></tr>`;
			statusBox.textContent = `${total} colecciones encontradas`;
			return;
		}

		tbody.innerHTML = result.data.map((c) => `
			<tr>
				<td>${escapeHtml(c.title)}</td>
				<td><span class="admin-badge ${badgeClass(c.editorialStatus)}">${statusLabel(c.editorialStatus)}</span></td>
				<td>${escapeHtml(truncate(c.description ?? "", 60))}</td>
				<td>${c.isOrdered ? "Si" : "No"}</td>
				<td>${c.updatedAt ? new Date(c.updatedAt).toLocaleDateString("es-ES") : "-"}</td>
				<td class="actions-cell">
					<button type="button" class="admin-btn admin-btn--sm" data-edit-id="${c.id}">Editar</button>
					<button type="button" class="admin-btn admin-btn--sm admin-btn--danger" data-delete-id="${c.id}" data-delete-title="${escapeHtml(c.title)}">Eliminar</button>
				</td>
			</tr>
		`).join("");

		tbody.querySelectorAll("[data-edit-id]").forEach((button) => {
			button.addEventListener("click", async () => {
				const id = (button as HTMLButtonElement).dataset.editId!;
				editingId = id;
				const api = await getApiClient();
				const col = await api.getCollectionById(id);
				if (!col) return;
				(document.getElementById("edit-title") as HTMLInputElement).value = col.title;
				(document.getElementById("edit-description") as HTMLTextAreaElement).value = col.description;
				(document.getElementById("edit-status") as HTMLSelectElement).value = col.editorialStatus;
				(document.getElementById("edit-ordered") as HTMLInputElement).checked = !!col.isOrdered;
				editError.textContent = "";
				editDialog.showModal();
			});
		});

		tbody.querySelectorAll("[data-delete-id]").forEach((button) => {
			button.addEventListener("click", () => {
				const btn = button as HTMLButtonElement;
				pendingDeleteId = btn.dataset.deleteId ?? null;
				const title = btn.dataset.deleteTitle ?? "esta coleccion";
				confirmMessage.textContent = `Seguro que deseas eliminar "${title}"?`;
				confirmDialog.showModal();
			});
		});

		statusBox.textContent = `${total} colecciones encontradas`;
	}

	// Create form
	createForm.addEventListener("submit", async (e) => {
		e.preventDefault();
		createFeedback.textContent = "";
		createFeedback.className = "";
		try {
			const api = await getApiClient();
			await api.createCollection({
				title: (document.getElementById("create-title") as HTMLInputElement).value,
				description: (document.getElementById("create-description") as HTMLTextAreaElement).value,
				isOrdered: (document.getElementById("create-ordered") as HTMLInputElement).checked,
			});
			createForm.reset();
			createFeedback.textContent = "Coleccion creada.";
			createFeedback.className = "admin-feedback admin-feedback--success";
			offset = 0;
			loadCollections();
		} catch {
			createFeedback.textContent = "Error al crear la coleccion.";
			createFeedback.className = "admin-feedback admin-feedback--error";
		}
	});

	// Edit form
	editForm.addEventListener("submit", async (e) => {
		e.preventDefault();
		if (!editingId) return;
		editError.textContent = "";
		try {
			const api = await getApiClient();
			const result = await api.updateCollection(editingId, {
				title: (document.getElementById("edit-title") as HTMLInputElement).value,
				description: (document.getElementById("edit-description") as HTMLTextAreaElement).value,
				editorialStatus: (document.getElementById("edit-status") as HTMLSelectElement).value,
				isOrdered: (document.getElementById("edit-ordered") as HTMLInputElement).checked,
			});
			if (!result.ok) {
				editError.textContent = result.error ?? "Error al guardar.";
				return;
			}
			editDialog.close();
			editingId = null;
			loadCollections();
		} catch {
			editError.textContent = "Error de conexion.";
		}
	});

	document.getElementById("edit-cancel")?.addEventListener("click", () => {
		editDialog.close();
		editingId = null;
	});

	// Delete confirmation
	confirmDialog.addEventListener("close", async () => {
		if (confirmDialog.returnValue === "confirm" && pendingDeleteId) {
			const api = await getApiClient();
			await api.deleteCollection(pendingDeleteId);
			pendingDeleteId = null;
			loadCollections();
		}
		pendingDeleteId = null;
	});

	// Filters
	document.getElementById("apply-filters")?.addEventListener("click", () => {
		offset = 0;
		loadCollections();
	});

	searchInput.addEventListener("keydown", (e) => {
		if (e.key === "Enter") {
			offset = 0;
			loadCollections();
		}
	});

	// Pagination
	prevBtn.addEventListener("click", () => {
		offset = Math.max(0, offset - limit);
		loadCollections();
	});

	nextBtn.addEventListener("click", () => {
		offset += limit;
		loadCollections();
	});

	loadCollections().catch(() => {
		window.location.href = url("login");
	});
</script>
