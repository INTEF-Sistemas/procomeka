---
import AdminLayout from "../../../layouts/AdminLayout.astro";
import { ResourceEditorIsland } from "../../../islands/resources/ResourceEditorIsland.tsx";
---

<AdminLayout title="Editar recurso" activeSection="resources">
	<div class="form-container">
		<h1>Editar recurso</h1>
		<ResourceEditorIsland client:load />
	</div>
</AdminLayout>

<style is:global>
	.form-container { max-width: 880px; margin: 0 auto; }
	.form-container h1 { margin-bottom: 1.5rem; }
	.form-container h2,
	.form-container h3 { margin: 0; }
	.form-container .eyebrow { text-transform: uppercase; letter-spacing: 0.08em; font-size: 0.75rem; color: #64748b; margin-bottom: 0.25rem; }

	/* --- Resource meta --- */
	.form-container .resource-meta {
		display: flex; gap: 0.5rem; align-items: center; flex-wrap: wrap;
		font-size: 0.85rem; color: #6b7280; background: #f9fafb;
		padding: 0.5rem 0.75rem; border-radius: 4px; margin-bottom: 1rem;
	}
	.form-container .meta-sep { color: #d1d5db; }

	/* --- Stepper --- */
	.form-container .workflow-section { margin-bottom: 1.5rem; }
	.form-container .stepper {
		display: flex; align-items: center; padding: 1rem 0;
	}
	.form-container .step {
		display: flex; flex-direction: column; align-items: center; gap: 0.4rem;
		flex-shrink: 0;
	}
	.form-container .step-dot {
		width: 18px; height: 18px; border-radius: 50%;
		background: #d1d5db; border: 2px solid #d1d5db;
		display: flex; align-items: center; justify-content: center;
		transition: background 0.2s, border-color 0.2s;
	}
	.form-container .step-label {
		font-size: 0.8rem; color: #6b7280; white-space: nowrap;
		transition: color 0.2s, font-weight 0.2s;
	}
	.form-container .step-line {
		flex: 1; height: 2px; background: #d1d5db; margin: 0 0.25rem;
		align-self: flex-start; margin-top: 10px;
		transition: background 0.2s;
	}

	/* Status colors: draft=red, review=orange, published=green */
	.form-container .step--active[data-status="draft"] .step-dot { background: #dc2626; border-color: #dc2626; }
	.form-container .step--active[data-status="draft"] .step-label { color: #dc2626; font-weight: 700; }
	.form-container .step--active[data-status="review"] .step-dot { background: #d97706; border-color: #d97706; }
	.form-container .step--active[data-status="review"] .step-label { color: #d97706; font-weight: 700; }
	.form-container .step--active[data-status="published"] .step-dot { background: #059669; border-color: #059669; }
	.form-container .step--active[data-status="published"] .step-label { color: #059669; font-weight: 700; }

	/* Completed step */
	.form-container .step--completed .step-dot { position: relative; }
	.form-container .step--completed .step-dot::after {
		content: "✓"; color: white; font-size: 0.65rem; font-weight: 700;
	}
	.form-container .step--completed[data-status="draft"] .step-dot { background: #dc2626; border-color: #dc2626; }
	.form-container .step--completed[data-status="draft"] .step-label { color: #374151; }
	.form-container .step--completed[data-status="review"] .step-dot { background: #d97706; border-color: #d97706; }
	.form-container .step--completed[data-status="review"] .step-label { color: #374151; }

	/* Lines between completed steps take the color of the previous step */
	.form-container .step-line--completed { background: #d1d5db; }
	.form-container .step-line--completed-draft { background: #dc2626; }
	.form-container .step-line--completed-review { background: #d97706; }

	/* Archived */
	.form-container .step--archived .step-dot { background: #9ca3af; border-color: #9ca3af; }
	.form-container .step--archived .step-label { color: #9ca3af; }
	.form-container .step-line--archived { background: #9ca3af; }
	.form-container .archived-badge {
		text-align: center; font-size: 0.85rem; font-weight: 600;
		color: #6b7280; background: #f3f4f6; padding: 0.35rem 0.75rem;
		border-radius: 4px; margin-bottom: 0.75rem;
	}

	/* Workflow actions */
	.form-container .workflow-actions { display: flex; flex-direction: column; gap: 0.5rem; margin-top: 0.25rem; }
	.form-container .wf-btn {
		width: 100%; padding: 0.75rem; border-radius: 4px; font-size: 1rem;
		cursor: pointer; font-weight: 600; border: 2px solid transparent;
		transition: opacity 0.15s;
	}
	.form-container .wf-btn[disabled] { opacity: 0.6; cursor: not-allowed; }
	.form-container .btn-outline {
		background: #fff; color: #374151; border-color: #d1d5db;
	}
	.form-container .btn-outline:hover:not([disabled]) { background: #f9fafb; }
	.form-container .btn-gold {
		background: #d97706; color: #fff; border-color: #d97706;
	}
	.form-container .btn-gold:hover:not([disabled]) { background: #b45309; }
	.form-container .btn-green {
		background: #059669; color: #fff; border-color: #059669;
	}
	.form-container .btn-green:hover:not([disabled]) { background: #047857; }
	.form-container .btn-gray {
		background: #6b7280; color: #fff; border-color: #6b7280;
	}
	.form-container .btn-gray:hover:not([disabled]) { background: #4b5563; }

	.form-container .sr-only {
		position: absolute; width: 1px; height: 1px;
		padding: 0; margin: -1px; overflow: hidden;
		clip: rect(0,0,0,0); white-space: nowrap; border: 0;
	}

	/* --- Form --- */
	.form-container .upload-panel {
		border: 1px solid #dbe4ee;
		border-radius: 14px;
		padding: 1rem;
		margin-bottom: 1.5rem;
		background: linear-gradient(180deg, #f8fafc 0%, #eef2f7 100%);
	}
	.form-container .upload-header {
		display: flex;
		justify-content: space-between;
		align-items: center;
		gap: 1rem;
		margin-bottom: 1rem;
	}
	.form-container .upload-picker {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.75rem 1rem;
		border-radius: 999px;
		background: #0f766e;
		color: white;
		font-weight: 700;
		cursor: pointer;
	}
	.form-container .upload-picker input {
		position: absolute;
		width: 1px;
		height: 1px;
		overflow: hidden;
		clip: rect(0, 0, 0, 0);
	}
	.form-container .upload-dropzone {
		border: 2px dashed #94a3b8;
		border-radius: 12px;
		padding: 1rem;
		background: white;
		color: #475569;
		margin-bottom: 0.75rem;
	}
	.form-container .upload-dropzone.is-dragover {
		border-color: #0f766e;
		background: #ecfeff;
	}
	.form-container .upload-feedback {
		min-height: 1.25rem;
		margin-bottom: 0.75rem;
		font-weight: 600;
	}
	.form-container .upload-feedback.success { color: #065f46; }
	.form-container .upload-feedback.error { color: #b91c1c; }
	.form-container .upload-progress-summary {
		display: grid;
		grid-template-columns: minmax(0, 1fr) auto;
		gap: 0.75rem;
		align-items: center;
		margin-bottom: 1rem;
	}
	.form-container .upload-progress-summary progress { width: 100%; }
	.form-container .upload-columns {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 1rem;
		margin-bottom: 1rem;
	}
	.form-container .upload-list {
		list-style: none;
		padding: 0;
		margin: 0.75rem 0 0;
		display: flex;
		flex-direction: column;
		gap: 0.65rem;
	}
	.form-container .upload-list li {
		display: grid;
		grid-template-columns: minmax(0, 1fr) auto auto auto;
		gap: 0.5rem;
		align-items: center;
		padding: 0.75rem;
		background: white;
		border: 1px solid #e2e8f0;
		border-radius: 10px;
	}
	.form-container .upload-list progress { width: 100%; }
	.form-container .upload-list button {
		width: auto;
		margin-top: 0;
		padding: 0.55rem 0.85rem;
		background: #fff;
		color: #334155;
		border: 1px solid #cbd5e1;
	}
	.form-container .upload-status {
		text-transform: uppercase;
		font-size: 0.72rem;
		font-weight: 700;
		letter-spacing: 0.05em;
	}
	.form-container .upload-status-uploading { color: #0f766e; }
	.form-container .upload-status-completed { color: #166534; }
	.form-container .upload-status-failed { color: #b91c1c; }
	.form-container .upload-status-cancelled { color: #64748b; }
	.form-container .upload-error { color: #b91c1c; }
	.form-container .field { margin-bottom: 1rem; }
	.form-container label { display: block; margin-bottom: 0.25rem; font-weight: 600; font-size: 0.9rem; }
	.form-container input,
	.form-container textarea,
	.form-container select {
		width: 100%; padding: 0.5rem; border: 1px solid #d1d5db;
		border-radius: 4px; font-size: 1rem; box-sizing: border-box;
	}
	.form-container input[aria-invalid="true"],
	.form-container textarea[aria-invalid="true"],
	.form-container select[aria-invalid="true"] {
		border-color: #dc2626;
	}
	.form-container textarea { resize: vertical; }
	.form-container .row { display: flex; gap: 1rem; }
	.form-container .row .field { flex: 1; }
	.form-container #submit-btn { display: none; }
	.form-container .error,
	.form-container .admin-feedback--error { background: #fee2e2; color: #991b1b; padding: 0.75rem; border-radius: 4px; margin-bottom: 1rem; }
	.form-container .success,
	.form-container .admin-feedback--success { background: #d1fae5; color: #065f46; padding: 0.75rem; border-radius: 4px; margin-bottom: 1rem; }
	.form-container .field-error { display: block; color: #dc2626; font-size: 0.8rem; margin-top: 0.2rem; min-height: 1rem; }
	.form-container #loading { color: #9ca3af; }
	@media (max-width: 720px) {
		.form-container .upload-header,
		.form-container .upload-columns,
		.form-container .row {
			grid-template-columns: 1fr;
			display: grid;
		}
		.form-container .upload-list li {
			grid-template-columns: 1fr;
		}
	}
</style>
