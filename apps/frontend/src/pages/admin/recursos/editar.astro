---
import AdminLayout from "../../../layouts/AdminLayout.astro";
---

<AdminLayout title="Editar recurso" activeSection="resources">
	<div class="form-container">
		<h1>Editar recurso</h1>

		<div id="auth-check" style="display:none;">
			<p>Necesitas <a id="login-link" href="#">iniciar sesión</a> como autor o superior para editar recursos.</p>
		</div>

		<div id="not-found" style="display:none;">
			<p>Recurso no encontrado.</p>
			<a id="dashboard-link" href="#">Volver al panel</a>
		</div>

		<div id="loading">Cargando recurso...</div>

		<div id="resource-meta" class="resource-meta" style="display:none;"></div>

		<section id="editorial-workflow" class="workflow-section" style="display:none;" aria-label="Estado editorial del recurso">
			<div class="stepper" role="group" aria-label="Progreso editorial">
				<div class="step" data-status="draft">
					<span class="step-dot" aria-hidden="true"></span>
					<span class="step-label">Borrador</span>
				</div>
				<div class="step-line" aria-hidden="true"></div>
				<div class="step" data-status="review">
					<span class="step-dot" aria-hidden="true"></span>
					<span class="step-label">En revisión</span>
				</div>
				<div class="step-line" aria-hidden="true"></div>
				<div class="step" data-status="published">
					<span class="step-dot" aria-hidden="true"></span>
					<span class="step-label">Aprobado</span>
				</div>
			</div>
			<div id="archived-badge" class="archived-badge" style="display:none;" role="status">Archivado</div>
			<p class="sr-only" id="status-announcement" aria-live="polite"></p>
			<div id="workflow-actions" class="workflow-actions"></div>
			<div id="workflow-error" class="error" role="alert" aria-live="polite" style="display:none;"></div>
			<div id="workflow-success" class="success" role="status" aria-live="polite" style="display:none;"></div>
		</section>

		<div id="error-message" class="error" role="alert" aria-live="polite" style="display:none;"></div>
		<div id="success-message" class="success" role="status" aria-live="polite" style="display:none;"></div>

		<form id="resource-form" style="display:none;" novalidate>
			<div class="field">
				<label for="title">Título *</label>
				<input type="text" id="title" required aria-describedby="title-error" />
				<span id="title-error" class="field-error" role="alert"></span>
			</div>

			<div class="field">
				<label for="description">Descripción *</label>
				<textarea id="description" rows="4" required aria-describedby="description-error"></textarea>
				<span id="description-error" class="field-error" role="alert"></span>
			</div>

			<div class="row">
				<div class="field">
					<label for="language">Idioma *</label>
					<select id="language" required aria-describedby="language-error">
						<option value="es">Español</option>
						<option value="en">Inglés</option>
						<option value="ca">Catalán</option>
						<option value="eu">Euskera</option>
						<option value="gl">Gallego</option>
					</select>
					<span id="language-error" class="field-error" role="alert"></span>
				</div>

				<div class="field">
					<label for="license">Licencia *</label>
					<select id="license" required aria-describedby="license-error">
						<option value="cc-by">CC BY</option>
						<option value="cc-by-sa">CC BY-SA</option>
						<option value="cc-by-nc">CC BY-NC</option>
						<option value="cc-by-nc-sa">CC BY-NC-SA</option>
						<option value="cc0">CC0 (Dominio público)</option>
					</select>
					<span id="license-error" class="field-error" role="alert"></span>
				</div>
			</div>

			<div class="field">
				<label for="resourceType">Tipo de recurso *</label>
				<select id="resourceType" required aria-describedby="resourceType-error">
					<option value="documento">Documento</option>
					<option value="presentacion">Presentación</option>
					<option value="video">Vídeo</option>
					<option value="audio">Audio</option>
					<option value="imagen">Imagen</option>
					<option value="actividad-interactiva">Actividad interactiva</option>
					<option value="secuencia-didactica">Secuencia didáctica</option>
					<option value="ejercicio">Ejercicio</option>
					<option value="evaluacion">Evaluación</option>
					<option value="proyecto">Proyecto</option>
				</select>
				<span id="resourceType-error" class="field-error" role="alert"></span>
			</div>

			<div class="field">
				<label for="author">Autor</label>
				<input type="text" id="author" aria-describedby="author-error" />
				<span id="author-error" class="field-error" role="alert"></span>
			</div>

			<div class="field">
				<label for="keywords">Palabras clave (separadas por comas)</label>
				<input type="text" id="keywords" placeholder="matemáticas, fracciones, visual" aria-describedby="keywords-error" />
				<span id="keywords-error" class="field-error" role="alert"></span>
			</div>

			<button type="submit" id="submit-btn">Guardar cambios</button>
		</form>
	</div>
</AdminLayout>

<script>
	import { getApiClient } from "../../../lib/get-api-client.ts";
	import { url } from "../../../lib/paths.ts";

	const form = document.getElementById("resource-form") as HTMLFormElement;
	const authCheck = document.getElementById("auth-check") as HTMLDivElement;
	const notFound = document.getElementById("not-found") as HTMLDivElement;
	const loadingDiv = document.getElementById("loading") as HTMLDivElement;
	const errorDiv = document.getElementById("error-message") as HTMLDivElement;
	const successDiv = document.getElementById("success-message") as HTMLDivElement;
	const workflowSection = document.getElementById("editorial-workflow") as HTMLElement;
	const workflowActions = document.getElementById("workflow-actions") as HTMLDivElement;
	const workflowError = document.getElementById("workflow-error") as HTMLDivElement;
	const workflowSuccess = document.getElementById("workflow-success") as HTMLDivElement;
	const statusAnnouncement = document.getElementById("status-announcement") as HTMLParagraphElement;
	const archivedBadge = document.getElementById("archived-badge") as HTMLDivElement;

	// Configurar enlaces con base path
	const loginLink = document.getElementById("login-link") as HTMLAnchorElement;
	const dashboardLink = document.getElementById("dashboard-link") as HTMLAnchorElement;
	if (loginLink) loginLink.href = url("login");
	if (dashboardLink) dashboardLink.href = url("dashboard");

	const params = new URLSearchParams(window.location.search);
	const resourceId = params.get("id");

	// Estado del flujo editorial
	let currentStatus = "draft";
	let userRole = "reader";

	const ROLE_LEVELS: Record<string, number> = { reader: 0, author: 1, curator: 2, admin: 3 };
	const STEPS = ["draft", "review", "published"] as const;
	const STEP_LABELS: Record<string, string> = {
		draft: "Borrador",
		review: "En revisión",
		published: "Aprobado",
	};
	const TRANSITION_RULES: Record<string, { to: string; minRole: string }[]> = {
		draft: [{ to: "review", minRole: "author" }],
		review: [{ to: "draft", minRole: "curator" }, { to: "published", minRole: "curator" }],
		published: [{ to: "archived", minRole: "curator" }],
		archived: [{ to: "draft", minRole: "curator" }],
	};
	const TRANSITION_LABELS: Record<string, string> = {
		"draft→review": "Enviar a revisión",
		"review→draft": "Devolver a borrador",
		"review→published": "Aprobar",
		"published→archived": "Archivar",
		"archived→draft": "Restaurar a borrador",
	};
	const TRANSITION_STYLES: Record<string, string> = {
		"draft→review": "btn-gold",
		"review→draft": "btn-outline",
		"review→published": "btn-green",
		"published→archived": "btn-gray",
		"archived→draft": "btn-outline",
	};

	function renderStepper(status: string) {
		const stepIndex = STEPS.indexOf(status as typeof STEPS[number]);
		const isArchived = status === "archived";

		document.querySelectorAll(".step").forEach((stepEl) => {
			const el = stepEl as HTMLElement;
			const stepStatus = el.dataset.status!;
			const idx = STEPS.indexOf(stepStatus as typeof STEPS[number]);

			el.classList.remove("step--active", "step--completed", "step--archived");
			el.removeAttribute("aria-current");

			if (isArchived) {
				el.classList.add("step--archived");
			} else if (idx === stepIndex) {
				el.classList.add("step--active");
				el.setAttribute("aria-current", "step");
			} else if (idx < stepIndex) {
				el.classList.add("step--completed");
			}
		});

		document.querySelectorAll(".step-line").forEach((lineEl, i) => {
			const el = lineEl as HTMLElement;
			el.classList.remove("step-line--completed", "step-line--completed-draft", "step-line--completed-review", "step-line--archived");
			if (isArchived) {
				el.classList.add("step-line--archived");
			} else if (i < stepIndex) {
				el.classList.add("step-line--completed");
				// Color the line based on the step it comes from
				if (i === 0) el.classList.add("step-line--completed-draft");
				if (i === 1) el.classList.add("step-line--completed-review");
			}
		});

		archivedBadge.style.display = isArchived ? "block" : "none";
		statusAnnouncement.textContent = `Estado actual: ${STEP_LABELS[status] ?? "Archivado"}`;
	}

	function renderActions(status: string, role: string) {
		workflowActions.innerHTML = "";
		const rules = TRANSITION_RULES[status] ?? [];
		const userLevel = ROLE_LEVELS[role] ?? 0;

		// Botón guardar (siempre visible como primera acción)
		const saveBtn = document.createElement("button");
		saveBtn.type = "button";
		saveBtn.className = "wf-btn btn-outline";
		saveBtn.innerHTML = "&#9998; Guardar cambios";
		saveBtn.setAttribute("aria-label", "Guardar cambios del recurso");
		saveBtn.addEventListener("click", () => {
			form.dispatchEvent(new Event("submit", { cancelable: true }));
		});
		workflowActions.appendChild(saveBtn);

		for (const rule of rules) {
			const minLevel = ROLE_LEVELS[rule.minRole] ?? 99;
			if (userLevel < minLevel) continue;

			const key = `${status}→${rule.to}`;
			const btn = document.createElement("button");
			btn.type = "button";
			btn.className = `wf-btn ${TRANSITION_STYLES[key] ?? "btn-outline"}`;
			btn.textContent = TRANSITION_LABELS[key] ?? rule.to;
			btn.setAttribute("aria-label", TRANSITION_LABELS[key] ?? `Cambiar a ${rule.to}`);
			btn.addEventListener("click", () => handleTransition(rule.to));
			workflowActions.appendChild(btn);
		}
	}

	async function handleTransition(targetStatus: string) {
		workflowError.style.display = "none";
		workflowSuccess.style.display = "none";

		const buttons = workflowActions.querySelectorAll("button");
		buttons.forEach((b) => { b.setAttribute("disabled", ""); b.setAttribute("aria-disabled", "true"); });

		try {
			const api = await getApiClient();
			await api.updateResourceStatus(resourceId!, targetStatus);
			currentStatus = targetStatus;
			renderStepper(currentStatus);
			renderActions(currentStatus, userRole);
			workflowSuccess.textContent = `Estado cambiado a: ${STEP_LABELS[currentStatus] ?? "Archivado"}`;
			workflowSuccess.style.display = "block";
			workflowSuccess.focus();
		} catch (err: unknown) {
			const errorObj = err as { error?: string; details?: { message: string }[] };
			const msg = errorObj?.details?.[0]?.message ?? errorObj?.error ?? "Error al cambiar el estado";
			workflowError.textContent = msg;
			workflowError.style.display = "block";
			workflowError.focus();
		} finally {
			buttons.forEach((b) => { b.removeAttribute("disabled"); b.removeAttribute("aria-disabled"); });
		}
	}

	function clearFieldErrors() {
		form.querySelectorAll(".field-error").forEach((el) => { el.textContent = ""; });
		form.querySelectorAll("[aria-invalid]").forEach((el) => { el.removeAttribute("aria-invalid"); });
	}

	function showFieldErrors(details: { field: string; message: string }[]) {
		for (const err of details) {
			const errorSpan = document.getElementById(`${err.field}-error`);
			const input = document.getElementById(err.field);
			if (errorSpan) errorSpan.textContent = err.message;
			if (input) input.setAttribute("aria-invalid", "true");
		}
	}

	async function init() {
		if (!resourceId) {
			loadingDiv.style.display = "none";
			notFound.style.display = "block";
			return;
		}

		try {
			const api = await getApiClient();
			const session = await api.getSession();
			if (!session?.user) { loadingDiv.style.display = "none"; authCheck.style.display = "block"; return; }

			userRole = session.user.role ?? "reader";
			const hierarchy = ["reader", "author", "curator", "admin"];
			if (hierarchy.indexOf(userRole) < 1) {
				loadingDiv.style.display = "none";
				authCheck.style.display = "block";
				return;
			}

			const r = await api.getResourceById(resourceId);
			if (!r) {
				loadingDiv.style.display = "none";
				notFound.style.display = "block";
				return;
			}

			currentStatus = r.editorialStatus ?? "draft";

			// Show resource metadata (creator info)
			const metaDiv = document.getElementById("resource-meta") as HTMLDivElement;
			const parts: string[] = [];
			if (r.createdByName) parts.push(`<span>Creado por: <strong>${r.createdByName}</strong></span>`);
			if (r.createdAt) {
				const d = new Date(typeof r.createdAt === "number" ? r.createdAt * 1000 : r.createdAt);
				parts.push(`<span>Fecha: ${d.toLocaleDateString("es-ES")}</span>`);
			}
			if (parts.length > 0) {
				metaDiv.innerHTML = parts.join('<span class="meta-sep">|</span>');
				metaDiv.style.display = "flex";
			}

			(document.getElementById("title") as HTMLInputElement).value = r.title ?? "";
			(document.getElementById("description") as HTMLTextAreaElement).value = r.description ?? "";
			(document.getElementById("language") as HTMLSelectElement).value = r.language ?? "es";
			(document.getElementById("license") as HTMLSelectElement).value = r.license ?? "cc-by";
			(document.getElementById("resourceType") as HTMLSelectElement).value = r.resourceType ?? "documento";
			(document.getElementById("author") as HTMLInputElement).value = r.author ?? "";
			(document.getElementById("keywords") as HTMLInputElement).value = r.keywords ?? "";

			renderStepper(currentStatus);
			renderActions(currentStatus, userRole);

			loadingDiv.style.display = "none";
			workflowSection.style.display = "block";
			form.style.display = "block";
		} catch {
			loadingDiv.style.display = "none";
			notFound.style.display = "block";
		}
	}

	form.addEventListener("submit", async (e) => {
		e.preventDefault();
		errorDiv.style.display = "none";
		successDiv.style.display = "none";
		clearFieldErrors();

		const body = {
			title: (document.getElementById("title") as HTMLInputElement).value,
			description: (document.getElementById("description") as HTMLTextAreaElement).value,
			language: (document.getElementById("language") as HTMLSelectElement).value,
			license: (document.getElementById("license") as HTMLSelectElement).value,
			resourceType: (document.getElementById("resourceType") as HTMLSelectElement).value,
			author: (document.getElementById("author") as HTMLInputElement).value || undefined,
			keywords: (document.getElementById("keywords") as HTMLInputElement).value || undefined,
		};

		try {
			const api = await getApiClient();
			const result = await api.updateResource(resourceId!, body);

			if (result.ok) {
				successDiv.textContent = "Recurso actualizado correctamente.";
				successDiv.style.display = "block";
			} else {
				if (result.details) {
					showFieldErrors(result.details);
				}
				errorDiv.textContent = result.error ?? "Error al actualizar el recurso";
				errorDiv.style.display = "block";
			}
		} catch {
			errorDiv.textContent = "Error de conexión";
			errorDiv.style.display = "block";
		}
	});

	init();
</script>

<style>
	.form-container { max-width: 600px; margin: 0 auto; }
	h1 { margin-bottom: 1.5rem; }

	/* --- Resource meta --- */
	.resource-meta {
		display: flex; gap: 0.5rem; align-items: center; flex-wrap: wrap;
		font-size: 0.85rem; color: #6b7280; background: #f9fafb;
		padding: 0.5rem 0.75rem; border-radius: 4px; margin-bottom: 1rem;
	}
	.meta-sep { color: #d1d5db; }

	/* --- Stepper --- */
	.workflow-section { margin-bottom: 1.5rem; }
	.stepper {
		display: flex; align-items: center; padding: 1rem 0;
	}
	.step {
		display: flex; flex-direction: column; align-items: center; gap: 0.4rem;
		flex-shrink: 0;
	}
	.step-dot {
		width: 18px; height: 18px; border-radius: 50%;
		background: #d1d5db; border: 2px solid #d1d5db;
		display: flex; align-items: center; justify-content: center;
		transition: background 0.2s, border-color 0.2s;
	}
	.step-label {
		font-size: 0.8rem; color: #6b7280; white-space: nowrap;
		transition: color 0.2s, font-weight 0.2s;
	}
	.step-line {
		flex: 1; height: 2px; background: #d1d5db; margin: 0 0.25rem;
		align-self: flex-start; margin-top: 10px;
		transition: background 0.2s;
	}

	/* Status colors: draft=red, review=orange, published=green */
	.step--active[data-status="draft"] .step-dot { background: #dc2626; border-color: #dc2626; }
	.step--active[data-status="draft"] .step-label { color: #dc2626; font-weight: 700; }
	.step--active[data-status="review"] .step-dot { background: #d97706; border-color: #d97706; }
	.step--active[data-status="review"] .step-label { color: #d97706; font-weight: 700; }
	.step--active[data-status="published"] .step-dot { background: #059669; border-color: #059669; }
	.step--active[data-status="published"] .step-label { color: #059669; font-weight: 700; }

	/* Completed step */
	.step--completed .step-dot { position: relative; }
	.step--completed .step-dot::after {
		content: "✓"; color: white; font-size: 0.65rem; font-weight: 700;
	}
	.step--completed[data-status="draft"] .step-dot { background: #dc2626; border-color: #dc2626; }
	.step--completed[data-status="draft"] .step-label { color: #374151; }
	.step--completed[data-status="review"] .step-dot { background: #d97706; border-color: #d97706; }
	.step--completed[data-status="review"] .step-label { color: #374151; }

	/* Lines between completed steps take the color of the previous step */
	.step-line--completed { background: #d1d5db; }
	.step-line--completed-draft { background: #dc2626; }
	.step-line--completed-review { background: #d97706; }

	/* Archived */
	.step--archived .step-dot { background: #9ca3af; border-color: #9ca3af; }
	.step--archived .step-label { color: #9ca3af; }
	.step-line--archived { background: #9ca3af; }
	.archived-badge {
		text-align: center; font-size: 0.85rem; font-weight: 600;
		color: #6b7280; background: #f3f4f6; padding: 0.35rem 0.75rem;
		border-radius: 4px; margin-bottom: 0.75rem;
	}

	/* Workflow actions */
	.workflow-actions { display: flex; flex-direction: column; gap: 0.5rem; margin-top: 0.25rem; }
	.wf-btn {
		width: 100%; padding: 0.75rem; border-radius: 4px; font-size: 1rem;
		cursor: pointer; font-weight: 600; border: 2px solid transparent;
		transition: opacity 0.15s;
	}
	.wf-btn[disabled] { opacity: 0.6; cursor: not-allowed; }
	.btn-outline {
		background: #fff; color: #374151; border-color: #d1d5db;
	}
	.btn-outline:hover:not([disabled]) { background: #f9fafb; }
	.btn-gold {
		background: #d97706; color: #fff; border-color: #d97706;
	}
	.btn-gold:hover:not([disabled]) { background: #b45309; }
	.btn-green {
		background: #059669; color: #fff; border-color: #059669;
	}
	.btn-green:hover:not([disabled]) { background: #047857; }
	.btn-gray {
		background: #6b7280; color: #fff; border-color: #6b7280;
	}
	.btn-gray:hover:not([disabled]) { background: #4b5563; }

	.sr-only {
		position: absolute; width: 1px; height: 1px;
		padding: 0; margin: -1px; overflow: hidden;
		clip: rect(0,0,0,0); white-space: nowrap; border: 0;
	}

	/* --- Form --- */
	.field { margin-bottom: 1rem; }
	label { display: block; margin-bottom: 0.25rem; font-weight: 600; font-size: 0.9rem; }
	input, textarea, select {
		width: 100%; padding: 0.5rem; border: 1px solid #d1d5db;
		border-radius: 4px; font-size: 1rem; box-sizing: border-box;
	}
	input[aria-invalid="true"], textarea[aria-invalid="true"], select[aria-invalid="true"] {
		border-color: #dc2626;
	}
	textarea { resize: vertical; }
	.row { display: flex; gap: 1rem; }
	.row .field { flex: 1; }
	#submit-btn { display: none; }
	.error { background: #fee2e2; color: #991b1b; padding: 0.75rem; border-radius: 4px; margin-bottom: 1rem; }
	.success { background: #d1fae5; color: #065f46; padding: 0.75rem; border-radius: 4px; margin-bottom: 1rem; }
	.field-error { display: block; color: #dc2626; font-size: 0.8rem; margin-top: 0.2rem; min-height: 1rem; }
	#loading { color: #9ca3af; }
</style>
