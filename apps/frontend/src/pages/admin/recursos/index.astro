---
import AdminLayout from "../../../layouts/AdminLayout.astro";
import { ResourcesTableIsland } from "../../../islands/crud/ResourcesTableIsland.tsx";
const base = import.meta.env.BASE_URL;
---

<AdminLayout title="Recursos" activeSection="resources">
	<section class="admin-page-head">
		<div>
			<p class="admin-eyebrow">Gestion</p>
			<h1>Recursos</h1>
			<p class="admin-helper">Listado editorial del backoffice con filtros, paginación y borrado desde una island React aislada.</p>
		</div>
		<a class="admin-btn admin-btn--primary" href={`${base}admin/recursos/nuevo`}>+ Nuevo recurso</a>
	</section>
	<ResourcesTableIsland client:load />
</AdminLayout>
