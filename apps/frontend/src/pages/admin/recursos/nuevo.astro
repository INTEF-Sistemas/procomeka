---
import AdminLayout from "../../../layouts/AdminLayout.astro";
---

<AdminLayout title="Crear recurso" activeSection="resources">
	<div class="form-container">
		<h1>Crear recurso</h1>

		<div id="auth-check" style="display:none;">
			<p>Necesitas <a id="login-link" href="#">iniciar sesión</a> como autor o superior para crear recursos.</p>
		</div>

		<div id="error-message" class="error" role="alert" aria-live="polite" style="display:none;"></div>
		<div id="success-message" class="success" role="status" aria-live="polite" style="display:none;"></div>

		<section id="elpx-drawer" class="elpx-drawer" style="display:none;">
			<div class="elpx-drawer-content">
				<div class="elpx-drawer-icon">📦</div>
				<h2>Sube un archivo .elpx</h2>
				<p>Arrastra un archivo .elpx de eXeLearning para crear el recurso con sus metadatos automáticamente.</p>
				<div id="elpx-dropzone" class="elpx-dropzone" tabindex="0">
					<label class="elpx-file-label">
						<span>Seleccionar archivo .elpx</span>
						<input type="file" id="elpx-file-input" accept=".elpx,.elp" />
					</label>
					<p class="elpx-drop-hint">o arrastra aquí</p>
				</div>
				<div id="elpx-loading" class="elpx-loading" style="display:none;">
					<span>Analizando archivo...</span>
				</div>
				<div id="elpx-error" class="elpx-error" role="alert" style="display:none;"></div>
				<button type="button" id="skip-elpx" class="skip-link">Crear recurso manualmente</button>
			</div>
		</section>

		<div id="elpx-success-banner" class="elpx-success-banner" style="display:none;"></div>

		<form id="resource-form" style="display:none;" novalidate>
			<div class="field">
				<label for="title">Título *</label>
				<input type="text" id="title" required aria-describedby="title-error" />
				<span id="title-error" class="field-error" role="alert"></span>
			</div>

			<div class="field">
				<label for="description">Descripción *</label>
				<textarea id="description" rows="4" required aria-describedby="description-error"></textarea>
				<span id="description-error" class="field-error" role="alert"></span>
			</div>

			<div class="row">
				<div class="field">
					<label for="language">Idioma *</label>
					<select id="language" required aria-describedby="language-error">
						<option value="es">Español</option>
						<option value="en">Inglés</option>
						<option value="ca">Catalán</option>
						<option value="eu">Euskera</option>
						<option value="gl">Gallego</option>
					</select>
					<span id="language-error" class="field-error" role="alert"></span>
				</div>

				<div class="field">
					<label for="license">Licencia *</label>
					<select id="license" required aria-describedby="license-error">
						<option value="cc-by">CC BY</option>
						<option value="cc-by-sa">CC BY-SA</option>
						<option value="cc-by-nc">CC BY-NC</option>
						<option value="cc-by-nc-sa">CC BY-NC-SA</option>
						<option value="cc0">CC0 (Dominio público)</option>
					</select>
					<span id="license-error" class="field-error" role="alert"></span>
				</div>
			</div>

			<div class="field">
				<label for="resourceType">Tipo de recurso *</label>
				<select id="resourceType" required aria-describedby="resourceType-error">
					<option value="documento">Documento</option>
					<option value="presentacion">Presentación</option>
					<option value="video">Vídeo</option>
					<option value="audio">Audio</option>
					<option value="imagen">Imagen</option>
					<option value="actividad-interactiva">Actividad interactiva</option>
					<option value="secuencia-didactica">Secuencia didáctica</option>
					<option value="ejercicio">Ejercicio</option>
					<option value="evaluacion">Evaluación</option>
					<option value="proyecto">Proyecto</option>
				</select>
				<span id="resourceType-error" class="field-error" role="alert"></span>
			</div>

			<div class="field">
				<label for="author">Autor</label>
				<input type="text" id="author" aria-describedby="author-error" />
				<span id="author-error" class="field-error" role="alert"></span>
			</div>

			<div class="field">
				<label for="keywords">Palabras clave (separadas por comas)</label>
				<input type="text" id="keywords" placeholder="matemáticas, fracciones, visual" aria-describedby="keywords-error" />
				<span id="keywords-error" class="field-error" role="alert"></span>
			</div>

			<button type="submit" id="submit-btn">Crear recurso</button>
		</form>
	</div>
</AdminLayout>

<script>
	import { getApiClient } from "../../../lib/get-api-client.ts";
	import { url, isPreviewMode } from "../../../lib/paths.ts";
	import { parseElpxMetadata as parseElpxClientSide } from "../../../lib/elpx-browser.ts";

	const form = document.getElementById("resource-form") as HTMLFormElement;
	const authCheck = document.getElementById("auth-check") as HTMLDivElement;
	const errorDiv = document.getElementById("error-message") as HTMLDivElement;
	const successDiv = document.getElementById("success-message") as HTMLDivElement;

	// Elpx drawer elements
	const elpxDrawer = document.getElementById("elpx-drawer") as HTMLElement;
	const elpxDropzone = document.getElementById("elpx-dropzone") as HTMLDivElement;
	const elpxFileInput = document.getElementById("elpx-file-input") as HTMLInputElement;
	const elpxLoading = document.getElementById("elpx-loading") as HTMLDivElement;
	const elpxError = document.getElementById("elpx-error") as HTMLDivElement;
	const skipElpxBtn = document.getElementById("skip-elpx") as HTMLButtonElement;
	const elpxSuccessBanner = document.getElementById("elpx-success-banner") as HTMLDivElement;

	// Form field references
	const titleInput = document.getElementById("title") as HTMLInputElement;
	const descriptionInput = document.getElementById("description") as HTMLTextAreaElement;
	const authorInput = document.getElementById("author") as HTMLInputElement;
	const languageSelect = document.getElementById("language") as HTMLSelectElement;
	const licenseSelect = document.getElementById("license") as HTMLSelectElement;
	const resourceTypeSelect = document.getElementById("resourceType") as HTMLSelectElement;

	// Stored elpx file for later upload
	let storedElpxFile: File | null = null;

	// Configurar enlaces con base path
	const loginLink = document.getElementById("login-link") as HTMLAnchorElement;
	if (loginLink) loginLink.href = url("login");

	function clearFieldErrors() {
		form.querySelectorAll(".field-error").forEach((el) => { el.textContent = ""; });
		form.querySelectorAll("[aria-invalid]").forEach((el) => { el.removeAttribute("aria-invalid"); });
	}

	function showFieldErrors(details: { field: string; message: string }[]) {
		for (const err of details) {
			const errorSpan = document.getElementById(`${err.field}-error`);
			const input = document.getElementById(err.field);
			if (errorSpan) errorSpan.textContent = err.message;
			if (input) input.setAttribute("aria-invalid", "true");
		}
	}

	async function checkAuth() {
		try {
			const api = await getApiClient();
			const session = await api.getSession();
			if (!session?.user) { authCheck.style.display = "block"; return; }

			const role = session.user.role ?? "reader";
			const hierarchy = ["reader", "author", "curator", "admin"];
			if (hierarchy.indexOf(role) < 1) {
				authCheck.style.display = "block";
				return;
			}
			// Show elpx drawer instead of form directly
			elpxDrawer.style.display = "block";
		} catch {
			authCheck.style.display = "block";
		}
	}

	// --- Elpx drawer logic ---

	function showFormOnly() {
		elpxDrawer.style.display = "none";
		form.style.display = "block";
	}

	skipElpxBtn.addEventListener("click", showFormOnly);

	elpxFileInput.addEventListener("change", () => {
		const file = elpxFileInput.files?.[0];
		if (file) handleElpxFile(file);
	});

	elpxDropzone.addEventListener("dragover", (e) => {
		e.preventDefault();
		elpxDropzone.classList.add("is-dragover");
	});

	elpxDropzone.addEventListener("dragleave", () => {
		elpxDropzone.classList.remove("is-dragover");
	});

	elpxDropzone.addEventListener("drop", (e) => {
		e.preventDefault();
		elpxDropzone.classList.remove("is-dragover");
		const file = e.dataTransfer?.files[0];
		if (file) handleElpxFile(file);
	});

	const isPreview = isPreviewMode();

	async function handleElpxFile(file: File) {
		elpxLoading.style.display = "block";
		elpxError.style.display = "none";

		try {
			let metadata: Record<string, string>;
			let filename: string;

			if (isPreview) {
				// Client-side parsing only -- storage happens at save time via saveElpxInPreview
				metadata = await parseElpxClientSide(file) as Record<string, string>;
				filename = file.name;
			} else {
				// Server-side parsing
				const formData = new FormData();
				formData.append("file", file);
				const res = await fetch(url("api/admin/elpx/analyze"), {
					method: "POST",
					credentials: "include",
					body: formData,
				});

				if (!res.ok) {
					const err = await res.json().catch(() => ({ error: "Error al analizar el archivo" }));
					elpxError.textContent = err.error || "Error al analizar el archivo";
					elpxError.style.display = "block";
					elpxLoading.style.display = "none";
					return;
				}

				const result = await res.json();
				metadata = result.metadata;
				filename = result.filename;
			}

			// Store file for later upload
			storedElpxFile = file;

			// Hide drawer, show form
			elpxDrawer.style.display = "none";
			form.style.display = "block";

			// Prefill fields from metadata
			if (metadata.title) titleInput.value = metadata.title;
			if (metadata.description) descriptionInput.value = metadata.description;
			if (metadata.author) authorInput.value = metadata.author;

			if (metadata.language) {
				const langOption = languageSelect.querySelector(`option[value="${metadata.language}"]`);
				if (langOption) languageSelect.value = metadata.language;
			}

			if (metadata.license) {
				const licOption = licenseSelect.querySelector(`option[value="${metadata.license}"]`);
				if (licOption) licenseSelect.value = metadata.license;
			}

			// Default resourceType for elpx files
			resourceTypeSelect.value = "actividad-interactiva";

			// Show success banner
			const displayName = filename || file.name;
			elpxSuccessBanner.textContent = `Metadatos extraídos de ${displayName}. Revisa y crea el recurso.`;
			elpxSuccessBanner.style.display = "block";
		} catch {
			elpxError.textContent = "Error de conexión al analizar el archivo";
			elpxError.style.display = "block";
		} finally {
			elpxLoading.style.display = "none";
		}
	}

	// --- Form submission ---

	form.addEventListener("submit", async (e) => {
		e.preventDefault();
		errorDiv.style.display = "none";
		successDiv.style.display = "none";
		clearFieldErrors();

		const body = {
			title: titleInput.value,
			description: descriptionInput.value,
			language: languageSelect.value,
			license: licenseSelect.value,
			resourceType: resourceTypeSelect.value,
			author: authorInput.value || undefined,
			keywords: (document.getElementById("keywords") as HTMLInputElement).value || undefined,
		};

		const submitBtn = document.getElementById("submit-btn") as HTMLButtonElement;
		submitBtn.disabled = true;
		submitBtn.textContent = "Creando recurso…";

		try {
			const api = await getApiClient();
			const data = await api.createResource(body);

			// If there's a stored .elpx file, upload it to the resource now
			if (storedElpxFile) {
				submitBtn.textContent = "Subiendo archivo .elpx…";

				if (isPreview) {
					try {
						const { saveElpxInPreview } = await import("../../../lib/elpx-preview-service.ts");
						await saveElpxInPreview({
							resourceId: data.id,
							blob: storedElpxFile,
							filename: storedElpxFile.name,
						});
					} catch (err) {
						console.error("Error guardando .elpx en preview:", err);
					}
				} else {
					const uploadForm = new FormData();
					uploadForm.append("file", storedElpxFile);

					const uploadRes = await fetch(url(`api/admin/elpx/upload/${data.id}`), {
						method: "POST",
						credentials: "include",
						body: uploadForm,
					});

					if (!uploadRes.ok) {
						const err = await uploadRes.json().catch(() => ({}));
						console.error("Error subiendo .elpx:", err);
						// Resource was created, redirect anyway — user can re-upload from edit page
					}
				}
			}

			successDiv.innerHTML = `Recurso creado. Redirigiendo al editor…`;
			successDiv.style.display = "block";
			window.setTimeout(() => {
				window.location.href = url(`admin/recursos/editar?id=${data.id}`);
			}, 500);
		} catch (err: unknown) {
			const e = err as { details?: { field: string; message: string }[]; error?: string };
			if (e?.details) {
				showFieldErrors(e.details);
			}
			errorDiv.textContent = e?.error ?? "Error al crear el recurso";
			errorDiv.style.display = "block";
		} finally {
			submitBtn.disabled = false;
			submitBtn.textContent = "Crear recurso";
		}
	});

	checkAuth();
</script>

<style is:global>
	.form-container { max-width: 600px; margin: 0 auto; }
	h1 { margin-bottom: 1.5rem; }
	.field { margin-bottom: 1rem; }
	label { display: block; margin-bottom: 0.25rem; font-weight: 600; font-size: 0.9rem; }
	input, textarea, select {
		width: 100%; padding: 0.5rem; border: 1px solid #d1d5db;
		border-radius: 4px; font-size: 1rem; box-sizing: border-box;
	}
	input[aria-invalid="true"], textarea[aria-invalid="true"], select[aria-invalid="true"] {
		border-color: #dc2626;
	}
	textarea { resize: vertical; }
	.row { display: flex; gap: 1rem; }
	.row .field { flex: 1; }
	button[type="submit"] {
		width: 100%; padding: 0.75rem; background: #1a56db; color: white;
		border: none; border-radius: 4px; font-size: 1rem; cursor: pointer; margin-top: 0.5rem;
	}
	button[type="submit"]:hover { background: #1e40af; }
	.error { background: #fee2e2; color: #991b1b; padding: 0.75rem; border-radius: 4px; margin-bottom: 1rem; }
	.success { background: #d1fae5; color: #065f46; padding: 0.75rem; border-radius: 4px; margin-bottom: 1rem; }
	.success a { color: #065f46; font-weight: 600; }
	.field-error { display: block; color: #dc2626; font-size: 0.8rem; margin-top: 0.2rem; min-height: 1rem; }

	/* Elpx drawer styles */
	.elpx-drawer {
		border: 2px solid #c7d2fe;
		border-radius: 16px;
		padding: 2rem;
		margin-bottom: 1.5rem;
		background: linear-gradient(135deg, #eef2ff 0%, #e0e7ff 50%, #c7d2fe 100%);
		text-align: center;
	}
	.elpx-drawer-icon { font-size: 3rem; margin-bottom: 0.5rem; }
	.elpx-drawer h2 { font-size: 1.3rem; margin: 0 0 0.5rem; color: #312e81; }
	.elpx-drawer p { color: #4338ca; font-size: 0.9rem; margin-bottom: 1rem; }
	.elpx-dropzone {
		border: 2px dashed #818cf8;
		border-radius: 12px;
		padding: 1.5rem;
		background: rgba(255,255,255,0.7);
		margin-bottom: 1rem;
		transition: border-color 0.15s, background 0.15s;
	}
	.elpx-dropzone.is-dragover {
		border-color: #4f46e5;
		background: rgba(255,255,255,0.95);
	}
	.elpx-file-label {
		display: inline-block;
		padding: 0.6rem 1.25rem;
		background: #4f46e5;
		color: white;
		border-radius: 999px;
		font-weight: 600;
		cursor: pointer;
		font-size: 0.9rem;
	}
	.elpx-file-label:hover { background: #4338ca; }
	.elpx-file-label input { position: absolute; width: 1px; height: 1px; overflow: hidden; clip: rect(0,0,0,0); }
	.elpx-drop-hint { color: #6366f1; font-size: 0.8rem; margin-top: 0.5rem; }
	.elpx-loading { color: #4338ca; font-weight: 600; padding: 1rem; }
	.elpx-error { background: #fee2e2; color: #991b1b; padding: 0.75rem; border-radius: 8px; margin-top: 0.5rem; }
	.skip-link {
		background: none; border: none; color: #6366f1; cursor: pointer;
		text-decoration: underline; font-size: 0.85rem; margin-top: 0.5rem;
	}
	.elpx-success-banner {
		background: #d1fae5; color: #065f46; padding: 0.75rem;
		border-radius: 8px; margin-bottom: 1rem; font-weight: 600;
	}
</style>
