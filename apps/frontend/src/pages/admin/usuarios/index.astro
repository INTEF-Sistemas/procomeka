---
import AdminLayout from "../../../layouts/AdminLayout.astro";
---

<AdminLayout title="Usuarios" activeSection="users">
	<section class="admin-page-head">
		<div>
			<p class="admin-eyebrow">Gestion</p>
			<h1>Usuarios</h1>
			<p class="admin-helper">El administrador puede filtrar y editar roles y estado. No se pueden crear ni eliminar usuarios desde aqui.</p>
		</div>
	</section>

	<section class="admin-toolbar">
		<label>
			Busqueda
			<input id="search" type="search" placeholder="Nombre o email" />
		</label>
		<label>
			Rol
			<select id="role-filter">
				<option value="">Todos</option>
				<option value="reader">Reader</option>
				<option value="author">Author</option>
				<option value="curator">Curator</option>
				<option value="admin">Admin</option>
			</select>
		</label>
		<button id="apply-filters" type="button" class="admin-btn">Aplicar</button>
	</section>

	<div id="list-status" class="admin-list-status" aria-live="polite"></div>

	<div class="admin-table-wrap">
		<table>
			<thead>
				<tr>
					<th>Nombre</th>
					<th>Email</th>
					<th>Rol</th>
					<th>Estado</th>
					<th>Actualizado</th>
					<th>Acciones</th>
				</tr>
			</thead>
			<tbody id="users-body"></tbody>
		</table>
	</div>

	<div class="admin-pager">
		<button id="prev-page" type="button" disabled>Anterior</button>
		<span id="page-label" class="admin-pager-label">Pagina 1</span>
		<button id="next-page" type="button" disabled>Siguiente</button>
	</div>

	<div id="save-feedback" class="admin-list-status" role="status" aria-live="polite"></div>
</AdminLayout>

<script>
	import { getApiClient } from "../../../lib/get-api-client.ts";
	import { url } from "../../../lib/paths.ts";

	const tbody = document.getElementById("users-body") as HTMLTableSectionElement;
	const statusBox = document.getElementById("list-status") as HTMLDivElement;
	const pageLabel = document.getElementById("page-label") as HTMLSpanElement;
	const prevBtn = document.getElementById("prev-page") as HTMLButtonElement;
	const nextBtn = document.getElementById("next-page") as HTMLButtonElement;
	const searchInput = document.getElementById("search") as HTMLInputElement;
	const roleFilter = document.getElementById("role-filter") as HTMLSelectElement;
	const saveFeedback = document.getElementById("save-feedback") as HTMLDivElement;

	let offset = 0;
	const limit = 20;
	let total = 0;

	function escapeHtml(str: string): string {
		const d = document.createElement("div");
		d.textContent = str;
		return d.innerHTML;
	}

	async function loadUsers() {
		statusBox.textContent = "Cargando usuarios...";
		const api = await getApiClient();
		const result = await api.listUsers({
			q: searchInput.value || undefined,
			role: roleFilter.value || undefined,
			limit,
			offset,
		});
		total = result.total;

		const pager = document.querySelector(".admin-pager") as HTMLElement;
		if (total <= limit) {
			pager.hidden = true;
		} else {
			pager.hidden = false;
			const page = Math.floor(offset / limit) + 1;
			const totalPages = Math.ceil(total / limit);
			pageLabel.textContent = `Pagina ${page} de ${totalPages}`;
			prevBtn.disabled = offset === 0;
			nextBtn.disabled = offset + limit >= total;
		}

		if (!result.data.length) {
			tbody.innerHTML = `<tr class="admin-empty-row"><td colspan="6">No hay usuarios para los filtros actuales.</td></tr>`;
			statusBox.textContent = `${total} usuarios encontrados`;
			return;
		}

		tbody.innerHTML = result.data.map((u) => `
			<tr>
				<td>${escapeHtml(u.name ?? "-")}</td>
				<td>${escapeHtml(u.email)}</td>
				<td>
					<select data-role-id="${u.id}">
						<option value="reader" ${u.role === "reader" ? "selected" : ""}>reader</option>
						<option value="author" ${u.role === "author" ? "selected" : ""}>author</option>
						<option value="curator" ${u.role === "curator" ? "selected" : ""}>curator</option>
						<option value="admin" ${u.role === "admin" ? "selected" : ""}>admin</option>
					</select>
				</td>
				<td>
					<span class="admin-badge ${u.isActive ? "admin-badge--active" : "admin-badge--inactive"}">
						${u.isActive ? "Activo" : "Inactivo"}
					</span>
				</td>
				<td>${u.updatedAt ? new Date(u.updatedAt).toLocaleDateString("es-ES") : "-"}</td>
				<td class="actions-cell">
					<button type="button" class="admin-btn admin-btn--sm" data-save-id="${u.id}">Guardar</button>
					<button type="button" class="admin-btn admin-btn--sm admin-btn--ghost" data-toggle-id="${u.id}" data-is-active="${u.isActive ? "1" : "0"}">
						${u.isActive ? "Desactivar" : "Activar"}
					</button>
				</td>
			</tr>
		`).join("");

		const api2 = await getApiClient();

		tbody.querySelectorAll("[data-save-id]").forEach((button) => {
			button.addEventListener("click", async () => {
				const id = (button as HTMLButtonElement).dataset.saveId!;
				const role = (tbody.querySelector(`[data-role-id="${id}"]`) as HTMLSelectElement)?.value ?? "reader";
				saveFeedback.textContent = "";
				saveFeedback.className = "admin-list-status";
				try {
					const result = await api2.updateUser(id, { role });
					if (result.ok) {
						saveFeedback.textContent = "Usuario actualizado.";
						saveFeedback.className = "admin-feedback admin-feedback--success";
					} else {
						saveFeedback.textContent = result.error ?? "Error al guardar.";
						saveFeedback.className = "admin-feedback admin-feedback--error";
					}
				} catch {
					saveFeedback.textContent = "Error de conexion.";
					saveFeedback.className = "admin-feedback admin-feedback--error";
				}
			});
		});

		tbody.querySelectorAll("[data-toggle-id]").forEach((button) => {
			button.addEventListener("click", async () => {
				const btn = button as HTMLButtonElement;
				const id = btn.dataset.toggleId!;
				const currentlyActive = btn.dataset.isActive === "1";
				saveFeedback.textContent = "";
				saveFeedback.className = "admin-list-status";
				try {
					const result = await api2.updateUser(id, { isActive: !currentlyActive });
					if (result.ok) {
						loadUsers();
					} else {
						saveFeedback.textContent = result.error ?? "Error al cambiar estado.";
						saveFeedback.className = "admin-feedback admin-feedback--error";
					}
				} catch {
					saveFeedback.textContent = "Error de conexion.";
					saveFeedback.className = "admin-feedback admin-feedback--error";
				}
			});
		});

		statusBox.textContent = `${total} usuarios encontrados`;
	}

	// Filters
	document.getElementById("apply-filters")?.addEventListener("click", () => {
		offset = 0;
		loadUsers();
	});

	searchInput.addEventListener("keydown", (e) => {
		if (e.key === "Enter") {
			offset = 0;
			loadUsers();
		}
	});

	// Pagination
	prevBtn.addEventListener("click", () => {
		offset = Math.max(0, offset - limit);
		loadUsers();
	});

	nextBtn.addEventListener("click", () => {
		offset += limit;
		loadUsers();
	});

	loadUsers().catch(() => {
		window.location.href = url("login");
	});
</script>
