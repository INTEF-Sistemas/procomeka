---
import AdminLayout from "../layouts/AdminLayout.astro";
import { DashboardIsland } from "../islands/dashboard/DashboardIsland.tsx";
---

<AdminLayout title="Panel" activeSection="dashboard">
	<section class="hero">
		<p class="eyebrow">Backoffice</p>
		<h1>Panel de gestión</h1>
		<p class="lead">Accede a los CRUD del catálogo según tu rol y continúa el flujo editorial desde un único punto.</p>
	</section>
	<DashboardIsland client:load />
</AdminLayout>
<style is:global>
	.hero {
		margin-bottom: 1.5rem;
	}

	.eyebrow {
		font-size: 0.78rem;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: #2b6cb0;
		font-weight: 700;
		margin-bottom: 0.5rem;
	}

	.lead {
		color: #4a5568;
		max-width: 60ch;
	}

	.summary-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
		gap: 1rem;
		margin-bottom: 1.5rem;
	}

	.summary-card,
	.dev-tools {
		border: 1px solid #d8dee9;
		border-radius: 14px;
		padding: 1rem;
		background: white;
	}

	.summary-card a {
		display: inline-block;
		margin-top: 0.75rem;
		font-weight: 600;
	}

	.seed-controls {
		display: flex;
		gap: 0.5rem;
		flex-wrap: wrap;
		align-items: center;
		margin-top: 0.75rem;
	}

	.btn-secondary,
	.btn-danger {
		border: none;
		border-radius: 8px;
		padding: 0.55rem 0.8rem;
		color: white;
		cursor: pointer;
	}

	.btn-secondary { background: #4a5568; }
	.btn-danger { background: #c53030; }
	.status-msg { margin-top: 0.75rem; font-weight: 600; }
	.status-msg.success { color: #276749; }
	.status-msg.error { color: #c53030; }
	.status-msg.loading { color: #2b6cb0; }
</style>
