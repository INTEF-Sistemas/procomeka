---
import Base from "../layouts/Base.astro";
---

<Base title="Panel">
	<div class="dashboard-container">
		<div id="loading">Cargando sesión...</div>

		<div id="not-authenticated" style="display:none;">
			<p>No has iniciado sesión.</p>
			<a id="login-link" href="#">Iniciar sesión</a>
		</div>

		<div id="authenticated" style="display:none;">
			<h1>Panel de <span id="user-name"></span></h1>
			<div class="user-info">
				<p><strong>Email:</strong> <span id="user-email"></span></p>
				<p><strong>Rol:</strong> <span id="user-role" class="badge"></span></p>
			</div>

			<div id="admin-section" class="section" style="display:none;">
				<h2>Administración</h2>
				<p>Tienes acceso de administrador. Puedes gestionar usuarios, recursos y colecciones.</p>

				<div id="dev-tools" class="dev-tools" style="display:none;">
					<h3>Herramientas de desarrollo</h3>
					<div class="seed-controls">
						<label for="seed-count">Generar recursos:</label>
						<select id="seed-count">
							<option value="10">10</option>
							<option value="100">100</option>
							<option value="1000">1.000</option>
							<option value="10000">10.000</option>
						</select>
						<button id="seed-btn" class="btn-secondary">Ejecutar</button>
						<button id="seed-clean-btn" class="btn-danger">Limpiar y Ejecutar</button>
					</div>
					<p id="seed-status" class="status-msg"></p>
				</div>
			</div>

			<div id="curator-section" class="section" style="display:none;">
				<h2>Curación</h2>
				<p>Puedes revisar y validar recursos del catálogo.</p>
			</div>

			<div id="author-section" class="section" style="display:none;">
				<h2>Mis recursos</h2>
				<a id="create-link" href="#" class="btn-create">Crear recurso</a>
				<div id="resources-list">
					<p class="loading-text">Cargando recursos...</p>
				</div>
			</div>

			<button id="logout-btn">Cerrar sesión</button>
		</div>
	</div>
</Base>

<script>
	import { getApiClient } from "../lib/get-api-client.ts";
	import { url } from "../lib/paths.ts";

	const STATUS_LABELS: Record<string, string> = {
		draft: "Borrador",
		review: "En revisión",
		published: "Publicado",
		archived: "Archivado",
	};

	// Configurar hrefs con base path
	const loginLink = document.getElementById("login-link") as HTMLAnchorElement;
	const createLink = document.getElementById("create-link") as HTMLAnchorElement;
	if (loginLink) loginLink.href = url("login");
	if (createLink) createLink.href = url("admin/recursos/nuevo");

	async function loadResources() {
		const container = document.getElementById("resources-list") as HTMLDivElement;
		try {
			const api = await getApiClient();
			const { data } = await api.listAdminResources();

			if (!data || data.length === 0) {
				container.innerHTML = "<p>No hay recursos todavía.</p>";
				return;
			}

			const rows = data.map((r) => {
				const status = r.editorialStatus ?? "draft";
				const label = STATUS_LABELS[status] ?? status;
				const date = r.createdAt;
				const dateStr = date ? new Date(typeof date === "number" ? date * 1000 : date).toLocaleDateString("es-ES") : "";
				return `<tr>
					<td>${r.title}</td>
					<td>${r.createdByName ?? ""}</td>
					<td><span class="badge badge-${status}">${label}</span></td>
					<td>${dateStr}</td>
					<td class="actions">
						<a href="${url(`admin/recursos/editar?id=${r.id}`)}" class="action-link">Editar</a>
						<button class="action-delete" data-id="${r.id}">Eliminar</button>
					</td>
				</tr>`;
			}).join("");

			container.innerHTML = `<table>
				<thead><tr><th>Título</th><th>Autor</th><th>Estado</th><th>Fecha</th><th>Acciones</th></tr></thead>
				<tbody>${rows}</tbody>
			</table>`;

			container.querySelectorAll(".action-delete").forEach((btn) => {
				btn.addEventListener("click", async () => {
					const id = (btn as HTMLButtonElement).dataset.id;
					if (!id || !confirm("¿Eliminar este recurso?")) return;
					const api = await getApiClient();
					await api.deleteResource(id);
					loadResources();
				});
			});
		} catch {
			container.innerHTML = "<p>Error de conexión.</p>";
		}
	}

	async function loadSession() {
		const loading = document.getElementById("loading") as HTMLDivElement;
		const notAuth = document.getElementById("not-authenticated") as HTMLDivElement;
		const auth = document.getElementById("authenticated") as HTMLDivElement;

		try {
			const api = await getApiClient();
			const session = await api.getSession();

			if (!session?.user) {
				loading.style.display = "none";
				notAuth.style.display = "block";
				return;
			}

			const user = session.user;
			(document.getElementById("user-name") as HTMLSpanElement).textContent = user.name;
			(document.getElementById("user-email") as HTMLSpanElement).textContent = user.email;

			const roleBadge = document.getElementById("user-role") as HTMLSpanElement;
			roleBadge.textContent = user.role ?? "reader";
			roleBadge.className = `badge badge-${user.role ?? "reader"}`;

			const role = user.role ?? "reader";
			const roleHierarchy = ["reader", "author", "curator", "admin"];
			const level = roleHierarchy.indexOf(role);

			if (level >= 1) {
				(document.getElementById("author-section") as HTMLDivElement).style.display = "block";
				loadResources();
			}
			if (level >= 2) {
				(document.getElementById("curator-section") as HTMLDivElement).style.display = "block";
			}
			if (level >= 3) {
				(document.getElementById("admin-section") as HTMLDivElement).style.display = "block";

				// Mostrar herramientas dev solo en desarrollo o preview
				const isDev = window.location.hostname === "localhost" ||
							(window as any).__PREVIEW_MODE__ === true;

				if (isDev) {
					const devTools = document.getElementById("dev-tools");
					if (devTools) devTools.style.display = "block";
				}
			}

			loading.style.display = "none";
			auth.style.display = "block";
		} catch {
			loading.style.display = "none";
			notAuth.style.display = "block";
		}
	}

	document.getElementById("logout-btn")?.addEventListener("click", async () => {
		const api = await getApiClient();
		await api.signOut();

		try {
			const config = await api.getConfig();
			if (config.oidcEnabled && config.oidcEndSessionUrl) {
				const returnUrl = `${window.location.origin}${url("login")}`;
				window.location.href = `${config.oidcEndSessionUrl}?post_logout_redirect_uri=${encodeURIComponent(returnUrl)}`;
				return;
			}
		} catch { /* logout local es suficiente */ }

		window.location.href = url("login");
	});

	// Lógica de seed
	const seedBtn = document.getElementById("seed-btn");
	const seedCleanBtn = document.getElementById("seed-clean-btn");
	const seedCount = document.getElementById("seed-count") as HTMLSelectElement;
	const seedStatus = document.getElementById("seed-status");

	async function runSeed(clean: boolean) {
		if (!confirm(clean ? "¿Borrar recursos generados y crear nuevos?" : "¿Generar recursos aleatorios?")) return;

		if (seedStatus) {
			seedStatus.textContent = "Generando... por favor espera.";
			seedStatus.className = "status-msg loading";
		}

		try {
			const api = await getApiClient();
			const count = Number(seedCount.value);
			const result = await api.seedResources(count, clean);

			if (seedStatus) {
				seedStatus.textContent = `¡Éxito! Creados ${result.count} recursos en ${result.durationMs}ms.`;
				seedStatus.className = "status-msg success";
			}
			loadResources();
		} catch (err: any) {
			if (seedStatus) {
				seedStatus.textContent = `Error: ${err.message}`;
				seedStatus.className = "status-msg error";
			}
		}
	}

	seedBtn?.addEventListener("click", () => runSeed(false));
	seedCleanBtn?.addEventListener("click", () => runSeed(true));

	loadSession();
</script>

<style>
	.dashboard-container {
		max-width: 700px;
		margin: 2rem auto;
		padding: 2rem;
	}

	.user-info {
		background: #f3f4f6;
		padding: 1rem;
		border-radius: 4px;
		margin-bottom: 1.5rem;
	}

	.user-info p {
		margin: 0.25rem 0;
	}

	.section {
		border: 1px solid #e5e7eb;
		padding: 1rem;
		border-radius: 4px;
		margin-bottom: 1rem;
	}

	.section h2 {
		margin-top: 0;
		font-size: 1.1rem;
	}

	.btn-create {
		display: inline-block;
		padding: 0.4rem 0.8rem;
		background: #1a56db;
		color: white;
		text-decoration: none;
		border-radius: 4px;
		font-size: 0.85rem;
		margin-bottom: 0.75rem;
	}
	.btn-create:hover { background: #1e40af; }

	.btn-secondary {
		background: #4b5563;
		color: white;
		border: none;
		padding: 0.3rem 0.7rem;
		border-radius: 4px;
		cursor: pointer;
		font-size: 0.85rem;
	}
	.btn-secondary:hover { background: #374151; }

	.btn-danger {
		background: #dc2626;
		color: white;
		border: none;
		padding: 0.3rem 0.7rem;
		border-radius: 4px;
		cursor: pointer;
		font-size: 0.85rem;
	}
	.btn-danger:hover { background: #b91c1c; }

	.dev-tools {
		margin-top: 1.5rem;
		padding-top: 1rem;
		border-top: 2px dashed #e5e7eb;
	}
	.dev-tools h3 {
		font-size: 0.9rem;
		margin-bottom: 0.75rem;
		color: #374151;
	}
	.seed-controls {
		display: flex;
		gap: 0.5rem;
		align-items: center;
		font-size: 0.85rem;
	}
	.status-msg {
		margin-top: 0.5rem;
		font-size: 0.8rem;
		font-weight: 500;
	}
	.status-msg.success { color: #059669; }
	.status-msg.error { color: #dc2626; }
	.status-msg.loading { color: #2563eb; }

	table {
		width: 100%;
		border-collapse: collapse;
		font-size: 0.85rem;
	}
	th, td {
		text-align: left;
		padding: 0.4rem 0.5rem;
		border-bottom: 1px solid #e5e7eb;
	}
	th { font-weight: 600; color: #6b7280; font-size: 0.8rem; text-transform: uppercase; }

	.actions { white-space: nowrap; }
	.action-link {
		color: #1a56db;
		text-decoration: none;
		margin-right: 0.5rem;
	}
	.action-link:hover { text-decoration: underline; }
	.action-delete {
		background: none;
		border: none;
		color: #dc2626;
		cursor: pointer;
		font-size: 0.85rem;
		padding: 0;
	}
	.action-delete:hover { text-decoration: underline; }

	.badge {
		display: inline-block;
		padding: 0.15rem 0.5rem;
		border-radius: 4px;
		font-size: 0.75rem;
		font-weight: 600;
		text-transform: uppercase;
	}

	.badge-admin { background: #fecaca; color: #991b1b; }
	.badge-curator { background: #dbeafe; color: #1e40af; }
	.badge-author { background: #d1fae5; color: #065f46; }
	.badge-reader { background: #e5e7eb; color: #374151; }
	.badge-draft { background: #fee2e2; color: #991b1b; }
	.badge-review { background: #fef3c7; color: #92400e; }
	.badge-published { background: #d1fae5; color: #065f46; }
	.badge-archived { background: #e5e7eb; color: #374151; }

	.loading-text { color: #9ca3af; }

	button {
		padding: 0.5rem 1rem;
		background: #dc2626;
		color: white;
		border: none;
		border-radius: 4px;
		cursor: pointer;
		margin-top: 1rem;
	}

	button:hover { background: #b91c1c; }

	a {
		color: #1a56db;
		text-decoration: underline;
	}
</style>
