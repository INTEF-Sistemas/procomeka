---
import Base from "../layouts/Base.astro";
---

<Base title="Inicio">
	<h1>Recursos educativos</h1>

	<div class="search-bar">
		<input type="text" id="search" placeholder="Buscar recursos..." />
	</div>

	<div id="resources-list" class="resources-list">
		<p class="loading">Cargando recursos...</p>
	</div>
</Base>

<script>
	import { getApiClient } from "../lib/get-api-client.ts";
	import { url } from "../lib/paths.ts";

	const list = document.getElementById("resources-list") as HTMLDivElement;
	const searchInput = document.getElementById("search") as HTMLInputElement;

	async function loadResources(query = "") {
		try {
			const api = await getApiClient();
			const { data, total } = await api.listResources(query ? { q: query } : undefined);

			if (data.length === 0) {
				list.innerHTML = "<p>No se encontraron recursos.</p>";
				return;
			}

			list.innerHTML = data
				.map(
					(r) => `
				<a href="${url(`recurso?slug=${r.slug}`)}" class="resource-card">
					<div class="card-header">
						<span class="badge badge-${r.resourceType}">${r.resourceType}</span>
						<span class="badge badge-status-${r.editorialStatus}">${r.editorialStatus}</span>
					</div>
					<h2>${r.title}</h2>
					<p>${r.description.slice(0, 150)}${r.description.length > 150 ? "..." : ""}</p>
				</a>
			`,
				)
				.join("");

			if (total > data.length) {
				list.innerHTML += `<p class="total">Mostrando ${data.length} de ${total} recursos</p>`;
			}
		} catch {
			list.innerHTML = "<p>Error al cargar recursos.</p>";
		}
	}

	let timeout: ReturnType<typeof setTimeout>;
	searchInput.addEventListener("input", () => {
		clearTimeout(timeout);
		timeout = setTimeout(() => loadResources(searchInput.value), 300);
	});

	loadResources();
</script>

<style>
	h1 { margin-bottom: 1rem; }

	.search-bar {
		margin-bottom: 1.5rem;
	}

	.search-bar input {
		width: 100%;
		padding: 0.75rem;
		border: 1px solid #d1d5db;
		border-radius: 6px;
		font-size: 1rem;
	}

	.resources-list {
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.resource-card {
		display: block;
		padding: 1rem;
		border: 1px solid #e5e7eb;
		border-radius: 6px;
		text-decoration: none;
		color: inherit;
		transition: border-color 0.15s;
	}

	.resource-card:hover {
		border-color: #1a56db;
	}

	.resource-card h2 {
		font-size: 1.1rem;
		margin: 0.5rem 0 0.25rem;
	}

	.resource-card p {
		color: #6b7280;
		font-size: 0.9rem;
		margin: 0;
	}

	.card-header {
		display: flex;
		gap: 0.5rem;
	}

	.badge {
		display: inline-block;
		padding: 0.1rem 0.4rem;
		border-radius: 3px;
		font-size: 0.7rem;
		font-weight: 600;
		text-transform: uppercase;
		background: #e5e7eb;
		color: #374151;
	}

	.badge-status-published { background: #d1fae5; color: #065f46; }
	.badge-status-draft { background: #fef3c7; color: #92400e; }
	.badge-status-review { background: #e0e7ff; color: #3730a3; }
	.badge-status-archived { background: #e5e7eb; color: #374151; }

	.loading { color: #9ca3af; }
	.total { color: #9ca3af; font-size: 0.85rem; text-align: center; }
</style>
