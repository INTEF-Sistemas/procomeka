---
import Base from "../layouts/Base.astro";
import {
	LANGUAGE_OPTIONS,
	LICENSE_OPTIONS,
	RESOURCE_TYPE_OPTIONS,
} from "../lib/resource-filters.ts";
---

<Base title="Inicio">
	<h1>Recursos educativos</h1>

	<div class="search-bar">
		<input type="text" id="search" placeholder="Buscar recursos..." aria-label="Buscar recursos" />
		<select id="filter-resource-type" aria-label="Filtrar por tipo de recurso">
			{RESOURCE_TYPE_OPTIONS.map((option) => (
				<option value={option.value}>{option.label}</option>
			))}
		</select>
		<select id="filter-language" aria-label="Filtrar por idioma">
			{LANGUAGE_OPTIONS.map((option) => (
				<option value={option.value}>{option.label}</option>
			))}
		</select>
		<select id="filter-license" aria-label="Filtrar por licencia">
			{LICENSE_OPTIONS.map((option) => (
				<option value={option.value}>{option.label}</option>
			))}
		</select>
	</div>

	<div id="results-summary" class="results-summary" aria-live="polite"></div>

	<div id="resources-list" class="resources-list" aria-live="polite">
		<p class="loading">Cargando recursos...</p>
	</div>

	<nav id="pagination" class="pagination" aria-label="Paginación de resultados" hidden>
		<button id="pagination-prev" type="button" class="pagination-button">Anterior</button>
		<p id="pagination-status" class="pagination-status"></p>
		<button id="pagination-next" type="button" class="pagination-button">Siguiente</button>
	</nav>
</Base>

<script>
	import { getApiClient } from "../lib/get-api-client.ts";
	import {
		buildListingUrl,
		readListingState,
		writeListingStateToHistory,
	} from "../lib/listing-history.ts";
	import { DEFAULT_PAGE_SIZE, getPaginationState } from "../lib/pagination.ts";
	import { url } from "../lib/paths.ts";

	const list = document.getElementById("resources-list") as HTMLDivElement;
	const resultsSummary = document.getElementById("results-summary") as HTMLDivElement;
	const searchInput = document.getElementById("search") as HTMLInputElement;
	const resourceTypeFilter = document.getElementById("filter-resource-type") as HTMLSelectElement;
	const languageFilter = document.getElementById("filter-language") as HTMLSelectElement;
	const licenseFilter = document.getElementById("filter-license") as HTMLSelectElement;
	const pagination = document.getElementById("pagination") as HTMLElement;
	const prevButton = document.getElementById("pagination-prev") as HTMLButtonElement;
	const nextButton = document.getElementById("pagination-next") as HTMLButtonElement;
	const paginationStatus = document.getElementById("pagination-status") as HTMLParagraphElement;

	let currentQuery = "";
	let currentPage = 1;
	let currentResourceType = "";
	let currentLanguage = "";
	let currentLicense = "";

	function readStateFromUrl() {
		const state = readListingState(window.location.search);
		currentQuery = state.query;
		currentPage = state.page;
		currentResourceType = state.resourceType;
		currentLanguage = state.language;
		currentLicense = state.license;
		searchInput.value = currentQuery;
		resourceTypeFilter.value = currentResourceType;
		languageFilter.value = currentLanguage;
		licenseFilter.value = currentLicense;
	}

	function writeStateToUrl(mode: "push" | "replace" = "replace") {
		const target = buildListingUrl(window.location.pathname, window.location.search, {
			query: currentQuery,
			page: currentPage,
			resourceType: currentResourceType,
			language: currentLanguage,
			license: currentLicense,
		});
		writeListingStateToHistory(window.history, target, mode);
	}

	function renderPagination(total: number, limit: number, offset: number) {
		const state = getPaginationState(total, limit, offset);

		if (total <= limit) {
			pagination.hidden = true;
			paginationStatus.textContent = "";
			return;
		}

		pagination.hidden = false;
		prevButton.disabled = !state.hasPreviousPage;
		nextButton.disabled = !state.hasNextPage;
		paginationStatus.textContent =
			`Pagina ${state.currentPage} de ${state.totalPages}. Mostrando ${state.startItem}-${state.endItem} de ${state.total}.`;
	}

	async function loadResources() {
		const offset = (currentPage - 1) * DEFAULT_PAGE_SIZE;

		try {
			const api = await getApiClient();
			const { data, total, limit, offset: resolvedOffset } = await api.listResources({
				q: currentQuery || undefined,
				limit: DEFAULT_PAGE_SIZE,
				offset,
				resourceType: currentResourceType || undefined,
				language: currentLanguage || undefined,
				license: currentLicense || undefined,
			});
			const state = getPaginationState(total, limit, resolvedOffset);

			if (state.currentPage !== currentPage) {
				currentPage = state.currentPage;
				writeStateToUrl("replace");
			}

			resultsSummary.textContent =
				total === 0
					? "No hay resultados para la busqueda actual."
					: `Mostrando ${state.startItem}-${state.endItem} de ${state.total} recursos.`;

			if (data.length === 0) {
				list.innerHTML = "<p>No se encontraron recursos.</p>";
				renderPagination(total, limit, resolvedOffset);
				return;
			}

			list.innerHTML = data
				.map(
					(r) => `
				<a href="${url(`recurso?slug=${r.slug}`)}" class="resource-card">
					<div class="card-header">
						<span class="badge badge-${r.resourceType}">${r.resourceType}</span>
						<span class="badge badge-status-${r.editorialStatus}">${r.editorialStatus}</span>
					</div>
					<h2>${r.title}</h2>
					<p>${r.description.slice(0, 150)}${r.description.length > 150 ? "..." : ""}</p>
				</a>
			`,
				)
				.join("");

			renderPagination(total, limit, resolvedOffset);
		} catch {
			list.innerHTML = "<p>Error al cargar recursos.</p>";
			resultsSummary.textContent = "";
			pagination.hidden = true;
		}
	}

	let timeout: ReturnType<typeof setTimeout>;
	searchInput.addEventListener("input", () => {
		clearTimeout(timeout);
		timeout = setTimeout(() => {
			currentQuery = searchInput.value.trim();
			currentPage = 1;
			writeStateToUrl("replace");
			loadResources();
		}, 300);
	});

	function handleFilterChange() {
		currentResourceType = resourceTypeFilter.value;
		currentLanguage = languageFilter.value;
		currentLicense = licenseFilter.value;
		currentPage = 1;
		writeStateToUrl("replace");
		loadResources();
	}

	resourceTypeFilter.addEventListener("change", handleFilterChange);
	languageFilter.addEventListener("change", handleFilterChange);
	licenseFilter.addEventListener("change", handleFilterChange);

	prevButton.addEventListener("click", () => {
		if (currentPage === 1) return;
		currentPage -= 1;
		writeStateToUrl("push");
		loadResources();
		window.scrollTo({ top: 0, behavior: "smooth" });
	});

	nextButton.addEventListener("click", () => {
		currentPage += 1;
		writeStateToUrl("push");
		loadResources();
		window.scrollTo({ top: 0, behavior: "smooth" });
	});

	window.addEventListener("popstate", () => {
		readStateFromUrl();
		loadResources();
	});

	readStateFromUrl();
	loadResources();
</script>

<style>
	h1 { margin-bottom: 1rem; }

	.search-bar {
		display: grid;
		grid-template-columns: minmax(0, 2fr) repeat(3, minmax(0, 1fr));
		gap: 0.75rem;
		margin-bottom: 1.5rem;
	}

	.search-bar input,
	.search-bar select {
		width: 100%;
		padding: 0.75rem;
		border: 1px solid #d1d5db;
		border-radius: 6px;
		font-size: 1rem;
		background: white;
	}

	.resources-list {
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.results-summary {
		margin-bottom: 1rem;
		color: #6b7280;
		font-size: 0.95rem;
	}

	.resource-card {
		display: block;
		padding: 1rem;
		border: 1px solid #e5e7eb;
		border-radius: 6px;
		text-decoration: none;
		color: inherit;
		transition: border-color 0.15s;
	}

	.resource-card:hover {
		border-color: #1a56db;
	}

	.resource-card h2 {
		font-size: 1.1rem;
		margin: 0.5rem 0 0.25rem;
	}

	.resource-card p {
		color: #6b7280;
		font-size: 0.9rem;
		margin: 0;
	}

	.card-header {
		display: flex;
		gap: 0.5rem;
	}

	.badge {
		display: inline-block;
		padding: 0.1rem 0.4rem;
		border-radius: 3px;
		font-size: 0.7rem;
		font-weight: 600;
		text-transform: uppercase;
		background: #e5e7eb;
		color: #374151;
	}

	.badge-status-published { background: #d1fae5; color: #065f46; }
	.badge-status-draft { background: #fef3c7; color: #92400e; }
	.badge-status-review { background: #e0e7ff; color: #3730a3; }
	.badge-status-archived { background: #e5e7eb; color: #374151; }

	.loading { color: #9ca3af; }

	.pagination {
		margin-top: 1.5rem;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		padding: 1rem;
		border: 1px solid #e5e7eb;
		border-radius: 10px;
		background: linear-gradient(180deg, #f8fafc 0%, #ffffff 100%);
	}

	.pagination-button {
		border: 1px solid #cbd5e1;
		background: white;
		color: #0f172a;
		padding: 0.7rem 1rem;
		border-radius: 999px;
		font-weight: 600;
		cursor: pointer;
		transition: background 0.15s, border-color 0.15s, color 0.15s;
	}

	.pagination-button:hover:not(:disabled) {
		background: #eff6ff;
		border-color: #93c5fd;
		color: #1d4ed8;
	}

	.pagination-button:disabled {
		cursor: not-allowed;
		opacity: 0.45;
	}

	.pagination-status {
		margin: 0;
		flex: 1;
		text-align: center;
		color: #475569;
		font-size: 0.95rem;
	}

	@media (max-width: 640px) {
		.search-bar {
			grid-template-columns: 1fr;
		}

		.pagination {
			flex-direction: column;
			align-items: stretch;
		}

		.pagination-status {
			order: -1;
		}
	}
</style>
