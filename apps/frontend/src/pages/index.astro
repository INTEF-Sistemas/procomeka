---
import Base from "../layouts/Base.astro";
import { CatalogIsland } from "../islands/catalog/CatalogIsland.tsx";
import { CatalogSearchIsland } from "../islands/catalog/CatalogSearchIsland.tsx";

const initialQuery = Astro.url.searchParams.get("q") ?? "";
---

<Base title="Inicio">
	<CatalogSearchIsland slot="header-center" client:load initialQuery={initialQuery} />
	<CatalogIsland client:load />
</Base>

<style is:global>
	.header-search-input { width: 100%; padding: 0.5rem 0.75rem; border: 1px solid #d1d5db; border-radius: 6px; font-size: 0.95rem; }

	.catalog { display: grid; grid-template-columns: 240px 1fr; gap: 1.5rem; align-items: start; }
	.sidebar { position: sticky; top: 4.5rem; border: 1px solid #e5e7eb; border-radius: 8px; padding: 1rem; background: #f9fafb; }
	.sidebar-title { font-size: 1rem; margin-bottom: 0.75rem; font-weight: 600; }
	.filter-group { margin-bottom: 0.75rem; }
	.filter-group label { display: block; font-size: 0.8rem; color: #6b7280; margin-bottom: 0.25rem; }
	.filter-group select { width: 100%; padding: 0.4rem; border: 1px solid #d1d5db; border-radius: 4px; font-size: 0.85rem; }
	.clear-btn { width: 100%; padding: 0.4rem; border: 1px solid #d1d5db; border-radius: 4px; background: #fff; cursor: pointer; font-size: 0.85rem; color: #6b7280; margin-top: 0.25rem; }
	.clear-btn:hover { background: #f3f4f6; }
	.toggle-sidebar-btn { display: none; padding: 0.4rem 0.75rem; border: 1px solid #d1d5db; border-radius: 4px; background: #fff; cursor: pointer; font-size: 0.85rem; }

	.toolbar { display: flex; align-items: center; gap: 0.75rem; margin-bottom: 1rem; flex-wrap: wrap; }
	.results-summary { color: #6b7280; font-size: 0.9rem; flex: 1; }
	.toolbar-right { display: flex; gap: 0.35rem; align-items: center; }
	.view-btn { width: 2rem; height: 2rem; border: 1px solid #d1d5db; border-radius: 4px; background: #fff; cursor: pointer; font-size: 1rem; line-height: 1; }
	.view-btn.active { background: #1a56db; color: #fff; border-color: #1a56db; }

	.resources-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1rem; }
	.resources-list-view { display: flex; flex-direction: column; gap: 0.75rem; }
	.resources-list-view .resource-card { flex-direction: row; }
	.resources-list-view .card-icon { font-size: 2rem; min-width: 3rem; }

	.resource-card { display: flex; flex-direction: column; padding: 1.1rem; border: 1px solid #e5e7eb; border-radius: 10px; text-decoration: none; color: inherit; background: #fff; transition: border-color 0.15s, box-shadow 0.2s, transform 0.15s; }
	.resource-card:hover { border-color: #93c5fd; box-shadow: 0 4px 16px rgba(26,86,219,0.1); transform: translateY(-2px); }
	.card-icon { font-size: 2.2rem; line-height: 1; margin-bottom: 0.5rem; }
	.card-body { flex: 1; display: flex; flex-direction: column; }
	.resource-card h3 { font-size: 1rem; font-weight: 600; margin: 0 0 0.35rem; color: #111827; line-height: 1.3; }
	.resource-card p { color: #6b7280; font-size: 0.84rem; margin: 0 0 0.6rem; line-height: 1.45; flex: 1; }

	.card-tags { display: flex; flex-wrap: wrap; gap: 0.35rem; margin-bottom: 0.3rem; }
	.pill { display: inline-block; padding: 0.15rem 0.5rem; border-radius: 999px; font-size: 0.68rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.02em; }
	.pill-type { background: #ede9fe; color: #6d28d9; }
	.pill-lang { background: #dbeafe; color: #1e40af; }
	.pill-license { background: #d1fae5; color: #065f46; }
	.card-meta { display: block; margin-top: 0.25rem; font-size: 0.75rem; color: #9ca3af; }

	.empty { color: #9ca3af; padding: 2rem 0; text-align: center; }
	.loading { color: #9ca3af; }

	.pagination { margin-top: 1.5rem; display: flex; align-items: center; justify-content: center; gap: 0.25rem; }
	.pag-btn { padding: 0.4rem 0.75rem; border: 1px solid #d1d5db; border-radius: 4px; background: #fff; cursor: pointer; font-size: 0.85rem; }
	.pag-btn:disabled { opacity: 0.4; cursor: not-allowed; }
	.pag-num { width: 2rem; height: 2rem; border: 1px solid #d1d5db; border-radius: 4px; background: #fff; cursor: pointer; font-size: 0.85rem; line-height: 2rem; text-align: center; }
	.pag-num.active { background: #1a56db; color: #fff; border-color: #1a56db; }
	.pag-ellipsis { padding: 0 0.25rem; color: #9ca3af; }

	@media (max-width: 768px) {
		.catalog { grid-template-columns: 1fr; }
		.sidebar { display: none; position: fixed; top: 0; left: 0; right: 0; bottom: 0; z-index: 200; border-radius: 0; overflow-y: auto; }
		.sidebar.open { display: block; }
		.toggle-sidebar-btn { display: inline-block; }
	}
</style>
