---
import Base from "../layouts/Base.astro";
import { LoginIsland } from "../islands/auth/LoginIsland.tsx";
---

<Base title="Iniciar sesión">
	<LoginIsland client:load />
</Base>
<style is:global>
	.login-container {
		max-width: 400px;
		margin: 2rem auto;
		padding: 2rem;
	}

	.login-container h1 {
		margin-bottom: 1.5rem;
	}

	.login-container .field {
		margin-bottom: 1rem;
	}

	.login-container label {
		display: block;
		margin-bottom: 0.25rem;
		font-weight: 600;
	}

	.login-container input {
		width: 100%;
		padding: 0.5rem;
		border: 1px solid #ccc;
		border-radius: 4px;
		font-size: 1rem;
		box-sizing: border-box;
	}

	.login-container button {
		width: 100%;
		padding: 0.75rem;
		background: #1a56db;
		color: white;
		border: none;
		border-radius: 4px;
		font-size: 1rem;
		cursor: pointer;
		margin-top: 0.5rem;
	}

	.login-container button:hover {
		background: #1e40af;
	}

	.login-container button:disabled {
		background: #93c5fd;
		cursor: not-allowed;
	}

	.login-container .separator {
		display: flex;
		align-items: center;
		margin: 1.5rem 0;
		color: #9ca3af;
		font-size: 0.85rem;
	}

	.login-container .separator::before,
	.login-container .separator::after {
		content: "";
		flex: 1;
		border-bottom: 1px solid #e5e7eb;
	}

	.login-container .separator span {
		padding: 0 0.75rem;
	}

	.login-container .oidc-btn {
		width: 100%;
		padding: 0.75rem;
		background: #fff;
		color: #374151;
		border: 1px solid #d1d5db;
		border-radius: 4px;
		font-size: 1rem;
		cursor: pointer;
	}

	.login-container .oidc-btn:hover {
		background: #f9fafb;
		border-color: #9ca3af;
	}

	.login-container .error {
		background: #fee2e2;
		color: #991b1b;
		padding: 0.75rem;
		border-radius: 4px;
		margin-bottom: 1rem;
	}

	.login-container .dev-info {
		margin-top: 2rem;
		padding: 1rem;
		background: #f3f4f6;
		border-radius: 4px;
		font-size: 0.875rem;
	}

	.login-container .dev-info ul {
		margin: 0.5rem 0 0;
		padding-left: 1.25rem;
	}

	.login-container .dev-info li {
		margin-bottom: 0.25rem;
	}

	.login-container code {
		background: #e5e7eb;
		padding: 0.1rem 0.3rem;
		border-radius: 2px;
		font-size: 0.8rem;
	}
</style>
