---
import Base from "../layouts/Base.astro";
---

<Base title="Recurso">
	<div id="resource-detail" class="detail-page">
		<p class="loading">Cargando recurso...</p>
	</div>
</Base>

<script>
	import { getApiClient } from "../lib/get-api-client.ts";
	import { url } from "../lib/paths.ts";
	import { escapeHtml, TYPE_ICONS, STATUS_MAP, FILE_ICONS, formatBytes } from "../lib/resource-display.ts";

	const container = document.getElementById("resource-detail") as HTMLDivElement;
	const slug = new URLSearchParams(window.location.search).get("slug");

	async function loadResource() {
		if (!slug) {
			container.innerHTML = `<p class="empty-state">No se especifico un recurso. <a href="${url("")}">Volver al catalogo</a></p>`;
			return;
		}

		try {
			const api = await getApiClient();
			const [r, session] = await Promise.all([
				api.getResourceBySlug(slug),
				api.getSession().catch(() => null),
			]);
			if (!r) {
				container.innerHTML = `<p class="empty-state">Recurso no encontrado. <a href="${url("")}">Volver al catalogo</a></p>`;
				return;
			}

			let editBtn = "";
			const role = session?.user?.role ?? "reader";
			const ROLES = ["reader", "author", "curator", "admin"];
			if (ROLES.indexOf(role) >= 1) {
				editBtn = `<a href="${url(`admin/recursos/editar?id=${r.id}`)}" class="edit-btn">Editar recurso</a>`;
			}

			const st = STATUS_MAP[r.editorialStatus] ?? STATUS_MAP.draft;
			const icon = TYPE_ICONS[r.resourceType] || "&#128196;";
			const date = r.createdAt ? new Date(r.createdAt).toLocaleDateString("es-ES", { year: "numeric", month: "long", day: "numeric" }) : "";

			const keywords = r.keywords
				? r.keywords.split(",").map((k: string) => `<span class="keyword">${escapeHtml(k.trim())}</span>`).join("")
				: "";

			const attachments = r.mediaItems?.length
				? r.mediaItems.map((m: Record<string, unknown>) => {
					const fileIcon = FILE_ICONS[m.mimeType as string] || "&#128193;";
					const size = m.fileSize ? formatBytes(m.fileSize as number) : "";
					return `
						<a href="${m.url}" class="file-card" download>
							<span class="file-icon">${fileIcon}</span>
							<div class="file-info">
								<span class="file-name">${escapeHtml((m.filename as string) || "Archivo")}</span>
								${size ? `<span class="file-size">${size}</span>` : ""}
							</div>
						</a>`;
				}).join("")
				: "";

			container.innerHTML = `
				<nav class="breadcrumb">
					<a href="${url("")}">Catalogo</a>
					<span class="sep">/</span>
					<span>${escapeHtml(r.title)}</span>
				</nav>

				<div class="detail-header">
					<div class="detail-icon">${icon}</div>
					<div class="detail-title-area">
						<h1>${escapeHtml(r.title)}</h1>
						<div class="detail-pills">
							<span class="pill pill-type">${escapeHtml(r.resourceType)}</span>
							<span class="pill pill-lang">${escapeHtml((r.language || "").toUpperCase())}</span>
							<span class="pill pill-license">${escapeHtml(r.license)}</span>
							<span class="pill ${st.cssClass}">${st.label}</span>
						</div>
					</div>
					${editBtn}
				</div>

				<div class="detail-content">
					<div class="detail-main">
						<section class="description-section">
							<h2>Descripcion</h2>
							<p>${escapeHtml(r.description)}</p>
						</section>

						${keywords ? `
						<section class="keywords-section">
							<h2>Palabras clave</h2>
							<div class="keywords-list">${keywords}</div>
						</section>` : ""}

						${attachments ? `
						<section class="files-section">
							<h2>Archivos adjuntos</h2>
							<div class="files-grid">${attachments}</div>
						</section>` : ""}
					</div>

					<aside class="detail-sidebar">
						<div class="meta-card">
							<h3>Informacion</h3>
							<dl class="meta-list">
								${r.author || r.createdByName ? `<dt>Autor</dt><dd>${escapeHtml(r.createdByName || r.author || "")}</dd>` : ""}
								${r.publisher ? `<dt>Editor</dt><dd>${escapeHtml(r.publisher)}</dd>` : ""}
								<dt>Idioma</dt><dd>${escapeHtml(r.language)}</dd>
								<dt>Licencia</dt><dd>${escapeHtml(r.license)}</dd>
								<dt>Tipo</dt><dd>${escapeHtml(r.resourceType)}</dd>
								${date ? `<dt>Publicado</dt><dd>${date}</dd>` : ""}
								${r.subjects?.length ? `<dt>Materias</dt><dd>${r.subjects.map((s: string) => escapeHtml(s)).join(", ")}</dd>` : ""}
								${r.levels?.length ? `<dt>Niveles</dt><dd>${r.levels.map((l: string) => escapeHtml(l)).join(", ")}</dd>` : ""}
							</dl>
						</div>
					</aside>
				</div>
			`;
		} catch {
			container.innerHTML = `<p class="empty-state">Error al cargar el recurso. <a href="${url("")}">Volver al catalogo</a></p>`;
		}
	}

	loadResource();
</script>

<style is:global>
	.detail-page { max-width: 960px; margin: 0 auto; }

	.breadcrumb { color: #6b7280; font-size: 0.85rem; margin-bottom: 1.25rem; }
	.breadcrumb a { color: #1a56db; text-decoration: none; }
	.breadcrumb a:hover { text-decoration: underline; }
	.breadcrumb .sep { margin: 0 0.4rem; color: #d1d5db; }

	.detail-header { display: flex; align-items: flex-start; gap: 1rem; margin-bottom: 2rem; padding-bottom: 1.5rem; border-bottom: 1px solid #e5e7eb; }
	.detail-icon { font-size: 3rem; line-height: 1; flex-shrink: 0; }
	.detail-title-area { flex: 1; }
	.detail-title-area h1 { font-size: 1.5rem; font-weight: 700; margin: 0 0 0.5rem; color: #111827; line-height: 1.3; }
	.detail-pills { display: flex; flex-wrap: wrap; gap: 0.4rem; }

	.pill { display: inline-block; padding: 0.2rem 0.6rem; border-radius: 999px; font-size: 0.72rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.02em; }
	.pill-type { background: #ede9fe; color: #6d28d9; }
	.pill-lang { background: #dbeafe; color: #1e40af; }
	.pill-license { background: #d1fae5; color: #065f46; }
	.pill-status-draft { background: #fee2e2; color: #991b1b; }
	.pill-status-review { background: #fef3c7; color: #92400e; }
	.pill-status-published { background: #d1fae5; color: #065f46; }
	.pill-status-archived { background: #e5e7eb; color: #374151; }

	.edit-btn { display: inline-block; padding: 0.5rem 1.25rem; background: #1a56db; color: #fff; text-decoration: none; border-radius: 6px; font-size: 0.85rem; font-weight: 600; white-space: nowrap; align-self: center; }
	.edit-btn:hover { background: #1e40af; }

	.detail-content { display: grid; grid-template-columns: 1fr 280px; gap: 2rem; align-items: start; }

	.detail-main section { margin-bottom: 2rem; }
	.detail-main h2 { font-size: 1.1rem; font-weight: 600; color: #374151; margin-bottom: 0.75rem; padding-bottom: 0.4rem; border-bottom: 1px solid #f3f4f6; }
	.description-section p { font-size: 1rem; line-height: 1.75; color: #374151; white-space: pre-line; }

	.keywords-list { display: flex; flex-wrap: wrap; gap: 0.4rem; }
	.keyword { display: inline-block; padding: 0.2rem 0.6rem; background: #f3f4f6; border-radius: 999px; font-size: 0.8rem; color: #4b5563; }

	.files-grid { display: grid; gap: 0.75rem; }
	.file-card { display: flex; align-items: center; gap: 0.75rem; padding: 0.75rem 1rem; border: 1px solid #e5e7eb; border-radius: 8px; text-decoration: none; color: inherit; transition: border-color 0.15s; }
	.file-card:hover { border-color: #93c5fd; }
	.file-icon { font-size: 1.5rem; }
	.file-info { display: flex; flex-direction: column; }
	.file-name { font-weight: 500; color: #1a56db; font-size: 0.9rem; }
	.file-size { font-size: 0.75rem; color: #9ca3af; }

	.detail-sidebar { position: sticky; top: 5rem; }
	.meta-card { background: #f9fafb; border: 1px solid #e5e7eb; border-radius: 8px; padding: 1.25rem; }
	.meta-card h3 { font-size: 0.95rem; font-weight: 600; margin: 0 0 0.75rem; color: #111827; }
	.meta-list { margin: 0; }
	.meta-list dt { font-size: 0.75rem; color: #9ca3af; text-transform: uppercase; letter-spacing: 0.05em; margin-top: 0.75rem; }
	.meta-list dt:first-child { margin-top: 0; }
	.meta-list dd { margin: 0.15rem 0 0; font-size: 0.9rem; color: #374151; }

	.empty-state { text-align: center; padding: 3rem 1rem; color: #6b7280; }
	.empty-state a { color: #1a56db; }
	.loading { color: #9ca3af; }

	@media (max-width: 768px) {
		.detail-header { flex-direction: column; }
		.detail-content { grid-template-columns: 1fr; }
		.detail-sidebar { position: static; }
	}
</style>
