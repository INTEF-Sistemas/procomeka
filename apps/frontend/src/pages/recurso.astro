---
import Base from "../layouts/Base.astro";
---

<Base title="Recurso">
	<div id="resource-detail">
		<p class="loading">Cargando recurso...</p>
	</div>
</Base>

<script>
	import { getApiClient } from "../lib/get-api-client.ts";
	import { url } from "../lib/paths.ts";

	const STATUS_LABELS: Record<string, string> = {
		draft: "Borrador",
		review: "En revisión",
		published: "Publicado",
		archived: "Archivado",
	};

	const container = document.getElementById("resource-detail") as HTMLDivElement;
	const params = new URLSearchParams(window.location.search);
	const slug = params.get("slug");

	async function loadResource() {
		if (!slug) {
			container.innerHTML = `<p>No se especificó un recurso.</p><a href='${url("")}'>Volver al inicio</a>`;
			return;
		}

		try {
			const api = await getApiClient();
			const r = await api.getResourceBySlug(slug);

			if (!r) {
				container.innerHTML = `<p>Recurso no encontrado.</p><a href='${url("")}'>Volver al inicio</a>`;
				return;
			}

			// Check if user can edit
			let editButton = "";
			try {
				const session = await api.getSession();
				if (session?.user) {
					const role = session.user.role ?? "reader";
					const hierarchy = ["reader", "author", "curator", "admin"];
					if (hierarchy.indexOf(role) >= 1) {
						editButton = `<a href="${url(`admin/recursos/editar?id=${r.id}`)}" class="btn-edit" aria-label="Editar recurso">Editar</a>`;
					}
				}
			} catch { /* no session, no edit button */ }

			const status = r.editorialStatus ?? "draft";
			const statusLabel = STATUS_LABELS[status] ?? status;
			const attachments = r.mediaItems?.length
				? `
					<section class="attachments">
						<h2>Archivos</h2>
						<ul class="attachment-list">
							${r.mediaItems.map((item) => `
								<li class="attachment-item">
									<a href="${item.url}" class="attachment-link" download>
										${item.filename ?? "Archivo adjunto"}
									</a>
									${item.fileSize ? `<span class="attachment-meta">${new Intl.NumberFormat("es-ES").format(item.fileSize)} bytes</span>` : ""}
								</li>
							`).join("")}
						</ul>
					</section>
				`
				: "";
			container.innerHTML = `
				<nav class="breadcrumb"><a href="${url("")}">Recursos</a> / ${r.title}</nav>
				<div class="title-row">
					<h1>${r.title}</h1>
					${editButton}
				</div>
				<div class="meta">
					<span class="badge">${r.resourceType}</span>
					<span class="badge badge-${status}">${statusLabel}</span>
					<span>${r.language}</span>
					<span>${r.license}</span>
				</div>
				<p class="description">${r.description}</p>
				${r.createdByName ? `<p class="field"><strong>Autor:</strong> ${r.createdByName}</p>` : (r.author ? `<p class="field"><strong>Autor:</strong> ${r.author}</p>` : "")}
				${r.publisher ? `<p class="field"><strong>Editor:</strong> ${r.publisher}</p>` : ""}
				${r.keywords ? `<p class="field"><strong>Palabras clave:</strong> ${r.keywords}</p>` : ""}
				${r.subjects?.length ? `<p class="field"><strong>Materias:</strong> ${r.subjects.join(", ")}</p>` : ""}
				${r.levels?.length ? `<p class="field"><strong>Niveles:</strong> ${r.levels.join(", ")}</p>` : ""}
				${attachments}
			`;
		} catch {
			container.innerHTML = "<p>Error al cargar el recurso.</p>";
		}
	}

	loadResource();
</script>

<style>
	.breadcrumb { color: #6b7280; font-size: 0.85rem; margin-bottom: 0.5rem; }
	.breadcrumb a { color: #1a56db; text-decoration: none; }
	.title-row { display: flex; align-items: center; gap: 1rem; margin-bottom: 0.75rem; }
	.title-row h1 { margin-bottom: 0; flex: 1; }
	.btn-edit {
		display: inline-block; padding: 0.4rem 1rem; background: #1a56db; color: white;
		text-decoration: none; border-radius: 4px; font-size: 0.85rem; font-weight: 600;
		white-space: nowrap;
	}
	.btn-edit:hover { background: #1e40af; }
	h1 { margin-bottom: 0.75rem; }
	.meta { display: flex; gap: 0.5rem; flex-wrap: wrap; margin-bottom: 1rem; color: #6b7280; font-size: 0.85rem; }
	.badge { padding: 0.1rem 0.4rem; border-radius: 3px; font-size: 0.7rem; font-weight: 600; text-transform: uppercase; background: #e5e7eb; color: #374151; }
	.badge-draft { background: #fee2e2; color: #991b1b; }
	.badge-review { background: #fef3c7; color: #92400e; }
	.badge-published { background: #d1fae5; color: #065f46; }
	.badge-archived { background: #e5e7eb; color: #374151; }
	.description { font-size: 1.05rem; line-height: 1.7; margin-bottom: 1.5rem; }
	.field { margin: 0.25rem 0; font-size: 0.9rem; }
	.attachments { margin-top: 2rem; padding-top: 1.25rem; border-top: 1px solid #e5e7eb; }
	.attachments h2 { margin: 0 0 0.75rem; font-size: 1.1rem; }
	.attachment-list { list-style: none; padding: 0; margin: 0; display: grid; gap: 0.75rem; }
	.attachment-item { display: flex; flex-wrap: wrap; gap: 0.75rem; align-items: baseline; }
	.attachment-link { color: #1a56db; font-weight: 600; text-decoration: none; }
	.attachment-link:hover { text-decoration: underline; }
	.attachment-meta { color: #6b7280; font-size: 0.85rem; }
	.loading { color: #9ca3af; }
</style>
