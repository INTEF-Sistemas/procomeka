{
  "name": "procomeka",
  "version": "1.0.0",
  "module": "apps/api/src/index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun run --filter '@procomeka/*' dev",
    "dev:api": "bun run --filter '@procomeka/api' dev",
    "dev:frontend": "bun run --filter '@procomeka/frontend' dev",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "test": "bun test --coverage apps/",
    "test:unit": "bun test --coverage apps/",
    "test:integration": "bun test --coverage apps/",
    "test:e2e": "playwright test --project=chromium",
    "check-coverage": "bun run scripts/check-coverage.ts",
    "test:e2e:firefox": "playwright test --project=firefox"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "@types/bun": "latest",
    "@playwright/test": "^1.42.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "biome": "^0.3.3"
  }
}
